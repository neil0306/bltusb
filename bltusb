    lang.unknown)     en="Unknown language: %s (available: en / zh-CN / zh-TW / auto)"; zh_cn="未知语言：%s（可用：en / zh-CN / zh-TW / auto）"; zh_tw="未知語言：%s（可用：en / zh-CN / zh-TW / auto）" ;;
    wiz.detecting)    en="Detecting external drives..."; zh_cn="正在检测外接设备…"; zh_tw="正在偵測外接裝置…" ;;
    wiz.none)         en="No external drive found. Plug in the USB drive and run bltusb again."; zh_cn="没有发现外接磁盘，请插入 U 盘后重新运行 bltusb"; zh_tw="找不到外接磁碟，請插入隨身碟後重新執行 bltusb" ;;
