#!/usr/bin/env bash
#
# bltusb — read/write BitLocker, NTFS, exFAT & more on macOS (Apple Silicon)
#          在 macOS 上读写 BitLocker / NTFS / exFAT 等外接盘
#
# Backed by the open-source anylinuxfs (no macFUSE / no kernel extension /
# no reduced system security). Run `bltusb` with no arguments for a guided,
# interactive mount. UI language auto-detects from the system and can be
# switched with `bltusb lang`.
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Constants & config
# ---------------------------------------------------------------------------
VERSION="1.3.1"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/bltusb"
CONFIG_FILE="$CONFIG_DIR/config"
KEYCHAIN_SERVICE="bltusb-anylinuxfs"
# Legacy global Keychain account (pre per-device model). No longer consulted on
# the mount path (that would cross drives); retained only so `forget --all`,
# which deletes every item under KEYCHAIN_SERVICE, still cleans it up.
# shellcheck disable=SC2034
KEYCHAIN_ACCOUNT="passphrase"
BITLOCKER_SIGNATURE="-FVE-FS-"   # BitLocker volume signature at offset 3

# Config values (overridable by the config file)
DEVICE=""            # empty = auto-detect each time
DEVICE_ID=""         # saved drive identity (UUID|label|bytes) to guard against diskN drift
DEFAULT_MODE="ro"    # read-only by default, safer
LANG_OVERRIDE=""     # empty = follow system language; else en / zh-CN / zh-TW

BLTUSB_LANG_CODE="en"   # resolved at startup

# ---------------------------------------------------------------------------
# Colors / output
# ---------------------------------------------------------------------------
if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_RED=$'\033[31m'; C_GRN=$'\033[32m'; C_YEL=$'\033[33m'
  C_BLU=$'\033[34m'; C_CYN=$'\033[36m'
else
  C_RESET=""; C_BOLD=""; C_DIM=""; C_RED=""; C_GRN=""; C_YEL=""; C_BLU=""; C_CYN=""
fi
info()  { printf '%s\n' "${C_CYN}▸${C_RESET} $*"; }
ok()    { printf '%s\n' "${C_GRN}✓${C_RESET} $*"; }
warn()  { printf '%s\n' "${C_YEL}⚠${C_RESET}  $*" >&2; }
err()   { printf '%s\n' "${C_RED}✗${C_RESET} $*" >&2; }
die()   { err "$*"; exit 1; }
step()  { printf '%s\n' "${C_BOLD}${C_BLU}==>${C_RESET} ${C_BOLD}$*${C_RESET}"; }

# ---------------------------------------------------------------------------
# Language detection & i18n
# ---------------------------------------------------------------------------
normalize_lang() {
  case "$1" in
    *Hant*|zh[-_]TW*|zh[-_]HK*|zh[-_]MO*) echo "zh-TW" ;;
    *Hans*|zh[-_]CN*|zh[-_]SG*|zh*)       echo "zh-CN" ;;
    en*|C|POSIX|"")                        echo "en" ;;
    *)                                     echo "en" ;;
  esac
}

# Precedence: env BLTUSB_LANG > config LANG_OVERRIDE > macOS locale > $LANG
resolve_lang() {
  local src="${BLTUSB_LANG:-${LANG_OVERRIDE:-}}"
  if [[ -z "$src" ]]; then
    src="$(defaults read -g AppleLocale 2>/dev/null || true)"
    [[ -z "$src" ]] && src="${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}"
  fi
  normalize_lang "$src"
}

lang_name() {
  case "$1" in
    en)    echo "English" ;;
    zh-CN) echo "简体中文" ;;
    zh-TW) echo "繁體中文" ;;
    *)     echo "$1" ;;
  esac
}

