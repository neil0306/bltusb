    wiz.moderw)       en="read-write"; zh_cn="读写"; zh_tw="讀寫" ;;
    wiz.modeask)      en="Select [default 1]: "; zh_cn="选择 [默认 1]: "; zh_tw="選擇 [預設 1]: " ;;
