    *)                en="$k"; zh_cn="$k"; zh_tw="$k" ;;
  esac
  case "$BLTUSB_LANG_CODE" in
    en)    m="$en" ;;
    zh-TW) m="$zh_tw" ;;
    *)     m="$zh_cn" ;;
  esac
  # SC2059 (variable format string) is intentional and safe here: $m is never
  # attacker-controlled — it is one of the hard-coded en/zh translation literals
  # selected by $k above. All external/untrusted values (device paths, mount
  # points, labels) arrive only as "$@" and are consumed strictly through the
  # translations' %s conversions, so they are substituted as data and never
  # re-interpreted as a printf format. (current_mountpoint() additionally
  # whitelists the one path that reaches a %s from `anylinuxfs status`.)
  # shellcheck disable=SC2059
  printf "$m" "$@"
}

# ---------------------------------------------------------------------------
# Config load/save
# ---------------------------------------------------------------------------
# Parse the config WITHOUT `source` so a hand-edited/crafted config can never
# execute code. Only known keys are honored; values are validated in main().
load_config() {
  [[ -f "$CONFIG_FILE" ]] || return 0
  local line key val
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"; val="${line#*=}"
    val="${val%\"}"; val="${val#\"}"   # strip one layer of surrounding quotes
    case "$key" in
      DEVICE)        DEVICE="$val" ;;
      DEVICE_ID)     DEVICE_ID="$val" ;;
      DEFAULT_MODE)  DEFAULT_MODE="$val" ;;
      LANG_OVERRIDE) LANG_OVERRIDE="$val" ;;
    esac
  done < "$CONFIG_FILE"
}

# Reject anything untrusted read from the config file (fail closed).
validate_config() {
  case "$DEFAULT_MODE" in ro|rw) ;; *) DEFAULT_MODE="ro" ;; esac
  case "$LANG_OVERRIDE" in ""|en|zh-CN|zh-TW) ;; *) LANG_OVERRIDE="" ;; esac
  [[ -z "$DEVICE" || "$DEVICE" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || DEVICE=""
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
# bltusb config — generated by \`bltusb config\` / \`bltusb lang\`, editable by hand
# DEVICE        : target partition, e.g. /dev/disk4s1; empty = auto-detect
# DEVICE_ID     : saved drive identity (UUID|label|bytes) — verified before use so a
#                 replug that shifts diskN numbers can't make bltusb touch a different disk
# DEFAULT_MODE  : default mount mode, ro (read-only, recommended) or rw (read-write)
# LANG_OVERRIDE : menu language, empty = follow system; en / zh-CN / zh-TW
DEVICE="${DEVICE}"
DEVICE_ID="${DEVICE_ID}"
DEFAULT_MODE="${DEFAULT_MODE}"
LANG_OVERRIDE="${LANG_OVERRIDE}"
EOF
  ok "$(t cfg.saved "${C_DIM}${CONFIG_FILE}${C_RESET}")"
}

# ---------------------------------------------------------------------------
# Password (stored PER DRIVE in the macOS Keychain)
# ---------------------------------------------------------------------------
# Each encrypted volume gets its own Keychain item keyed by a stable per-volume
# identity, so N drives with different passwords never overwrite each other.
# keychain_* take the account (device key) as an argument.
keychain_get() {   # <account>
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" -w 2>/dev/null || true
}
keychain_set() {   # <password> <account>
  # Feed the password on stdin instead of on argv: `-w` with NO value makes
  # `security` read the secret interactively, so the plaintext never appears in
  # the process argv where a concurrent `ps` could read it. The interactive form
  # prompts for the password twice (enter + confirm), so send it on two lines.
  printf '%s\n%s\n' "$1" "$1" \
    | security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$2" -w >/dev/null 2>&1
}
keychain_del() {   # <account>
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" >/dev/null 2>&1 || true
}

# A stable Keychain account for a specific volume. GPT partitions have a
# Partition UUID; MBR/BitLocker-To-Go drives don't, so fall back to a
# fingerprint of the boot sector (contains the BitLocker volume GUID; stable
# across replug, changes only on re-encryption — which is the desired reset).
device_key() {
  local dev="$1" uuid b64 fp
  uuid="$(diskutil info "$dev" 2>/dev/null | awk -F': +' '/Partition UUID/{print $2; exit}')"
  if [[ -n "$uuid" ]]; then printf 'puuid:%s' "$uuid"; return 0; fi
  # No UUID — fall back to a boot-sector fingerprint. Do NOT stage the sector in a
  # temp file: a `mktemp` path is predictable enough that an attacker can swap it
  # for a symlink between create and write, redirecting root's `dd of=...` onto an
  # arbitrary file (classic symlink TOCTOU). Instead carry the sector through a
  # pipe. The sector contains NUL bytes, which command substitution strips, so
  # base64-encode it in the pipeline (base64 in a shell variable is NUL-safe) and
  # require EXACTLY 512 raw bytes — i.e. 684 base64 chars — before hashing. A cold
  # `sudo -n` (or a short read) yields zero/short output, whose length check fails.
  # Hashing an empty read would otherwise mint a non-empty but bogus, shared key
  # that collides across every drive whose read failed — breaking per-volume
  # identity and silently no-op'ing `forget`. Emit nothing (return 1) so callers
  # that test `[[ -n "$key" ]]` correctly treat a failed read as "no stable
  # identity". The hash is over the DECODED 512 raw bytes, so the fingerprint is
  # byte-identical to a direct `dd | shasum` (and to the test's dev_key()).
  b64="$(sudo -n dd if="/dev/r${dev#/dev/}" bs=512 count=1 2>/dev/null | base64 2>/dev/null | tr -d '\n')"
  [[ ${#b64} -eq 684 ]] || return 1
  fp="$(printf '%s' "$b64" | base64 -d 2>/dev/null | shasum -a 256 | cut -c1-32)"
  [[ -n "$fp" ]] && printf 'fp:%s' "$fp"
}

# 48-digit BitLocker recovery key (8 groups of 6 digits)? Accept both the
# hyphenated form (######-######-…) and 48 contiguous digits with no
# separators — the prompt tells users to enter a "48-digit recovery key", so a
# pasted un-hyphenated key must be recognized too and never offered for saving.
is_recovery_key() { [[ "$1" =~ ^[0-9]{6}(-[0-9]{6}){7}$ || "$1" =~ ^[0-9]{48}$ ]]; }

# Non-interactive password for THIS volume only: env ALFS_PASSPHRASE > this
# drive's own Keychain item. The legacy global item is intentionally NOT
# consulted here — it belongs to a different (or unknown) drive and auto-trying
# it against the current volume would violate the per-volume password model
# (and could silently auto-unlock a different reused-password drive). Never
# returns another drive's secret. Arg 1 = device key (may be empty).
# The password is printed to stdout (captured by the caller); any human-facing
# note goes to stderr so it never contaminates the returned secret.
get_passphrase_quiet() {   # <device_key>
  if [[ -n "${ALFS_PASSPHRASE:-}" ]]; then
    info "${C_DIM}$(t pass.envnote)${C_RESET}" >&2
    printf '%s' "$ALFS_PASSPHRASE"; return 0
  fi
  local p=""
  [[ -n "$1" ]] && p="$(keychain_get "$1")"
  # Migration fallback: older versions stored ONE global item. Consult it only as
  # a last resort (this drive has no per-device item yet) so existing users keep
  # working seamlessly after upgrade — first unlock then saves a per-device item.
  # Not a cross-drive leak: anylinuxfs is a local decryptor, and a value that
  # doesn't fit this drive simply falls through to the re-prompt path.
  [[ -z "$p" ]] && p="$(keychain_get "$KEYCHAIN_ACCOUNT")"
  printf '%s' "$p"
}

# Prompt for the passphrase (or recovery key). Does NOT save — saving is offered
# separately, only after a successful mount (opt-in).
prompt_passphrase_only() {
  printf '%s' "${C_CYN}$(t pass.prompt)${C_RESET}" >&2
  # Clear IFS so leading/trailing whitespace in the password is preserved
  # byte-for-byte — the default IFS would trim it, breaking valid BitLocker
  # passwords that begin or end with spaces.
  local pw; IFS= read -rs pw; printf '\n' >&2
  [[ -n "$pw" ]] || die "$(t pass.empty)"
  printf '%s' "$pw"
}

# After a successful unlock, offer to remember THIS drive's password (default No).
# Recovery keys are never stored. Needs a stable device key.
offer_save() {   # <password> <device_key>
  [[ -n "$2" ]] || return 0
  if is_recovery_key "$1"; then info "${C_DIM}$(t pass.rknosave)${C_RESET}"; return 0; fi
  printf '%s' "${C_CYN}$(t pass.savekey)${C_RESET}" >&2
  local ans; read -r ans
  case "${ans:-N}" in [yY]*) keychain_set "$1" "$2" && ok "$(t cfg.pwsaved)" ;; *) : ;; esac
}

# ---------------------------------------------------------------------------
# Dependency check / install
# ---------------------------------------------------------------------------
have_anylinuxfs() { command -v anylinuxfs >/dev/null 2>&1; }

ensure_installed() {
  have_anylinuxfs && return 0
  warn "$(t inst.notfound)"
  printf '%s' "$(t inst.ask)" >&2
  local ans; read -r ans
  case "${ans:-Y}" in
    [nN]*) die "$(t inst.cancelled)" ;;
    *) cmd_install ;;
  esac
}

cmd_install() {
  step "$(t inst.header)"
  command -v brew >/dev/null 2>&1 || die "$(t inst.nobrew)"
  if have_anylinuxfs; then
    ok "$(t inst.already "$(anylinuxfs --version 2>/dev/null || echo ready)")"
    return 0
  fi
  info "brew tap nohajc/anylinuxfs"
  brew tap nohajc/anylinuxfs
  info "brew trust nohajc/anylinuxfs  ${C_DIM}# $(t inst.trustnote)${C_RESET}"
  brew trust nohajc/anylinuxfs || warn "$(t inst.trustfail)"
  info "brew install anylinuxfs"
  brew install anylinuxfs
  if have_anylinuxfs; then ok "$(t inst.done)"; else die "$(t inst.missing)"; fi
}

# ---------------------------------------------------------------------------
# Device detection
# ---------------------------------------------------------------------------
# Read <count> bytes at absolute byte <offset> from a raw device. Raw char
# devices require sector-aligned reads, so read the containing 512B sector and
# then slice (a bare `dd bs=1 skip=N` on /dev/rdiskN fails with "Invalid
# argument"). Needs sudo.
_devbytes() {
  local dev="${1#/dev/}" off="$2" cnt="$3" sec rem
  sec=$(( off / 512 )); rem=$(( off % 512 ))
  sudo -n dd if="/dev/r${dev}" bs=512 count=1 skip="$sec" 2>/dev/null \
    | dd bs=1 skip="$rem" count="$cnt" 2>/dev/null
}

# Classify a partition's filesystem from its on-disk signatures.
# Echoes one of: bitlocker luks ntfs exfat fat ext apfs unknown
fstype() {
  local dev="$1" oem
  # Every read is non-fatal (|| true): a failed sudo/dd must yield "unknown",
  # never abort the script under `set -euo pipefail`.
  oem="$(_devbytes "$dev" 3 8 | LC_ALL=C tr -d '\000' || true)"
  case "$oem" in
    "$BITLOCKER_SIGNATURE") echo bitlocker; return ;;
    NTFS*)                  echo ntfs;  return ;;
    EXFAT*)                 echo exfat; return ;;
  esac
  [[ "$(_devbytes "$dev" 0 4 | LC_ALL=C tr -d '\000' || true)" == "LUKS" ]] && { echo luks; return; }
  case "$(_devbytes "$dev" 82 8 | LC_ALL=C tr -d '\000' || true)" in FAT32*) echo fat; return ;; esac
  case "$(_devbytes "$dev" 54 8 | LC_ALL=C tr -d '\000' || true)" in FAT12*|FAT16*) echo fat; return ;; esac
  [[ "$(_devbytes "$dev" 32 4 | LC_ALL=C tr -d '\000' || true)" == "NXSB" ]] && { echo apfs; return; }
  [[ "$(_devbytes "$dev" 1080 2 | xxd -p 2>/dev/null || true)" == "53ef" ]] && { echo ext; return; }
  echo unknown
}

# Does this filesystem need a passphrase to unlock?
fs_is_encrypted() { case "$1" in bitlocker|luks) return 0 ;; *) return 1 ;; esac; }
# A known, plain (non-encrypted) filesystem we can mount without a password.
fs_is_plain()     { case "$1" in ntfs|exfat|ext|fat) return 0 ;; *) return 1 ;; esac; }
# Is this a filesystem anylinuxfs can mount for us?
fs_is_mountable() { case "$1" in bitlocker|luks|ntfs|exfat|ext|fat) return 0 ;; *) return 1 ;; esac; }

# Heuristic: does the partition type look like a Windows/BitLocker volume?
looks_windows() {
  case "$1" in
    *Windows*|*Microsoft*|*NTFS*|*BitLocker*|*FAT*) return 0 ;;
    *) return 1 ;;
  esac
}

# List partition identifiers (diskNsM) on all external physical disks
list_external_partitions() {
  diskutil list external physical 2>/dev/null \
    | grep -oE 'disk[0-9]+s[0-9]+' | sort -u
}

# Emit one row per external partition: "id<TAB>size<TAB>type"
list_partition_rows() {
  diskutil list external physical 2>/dev/null | awk '
    /^ +[0-9]+:/ && $NF ~ /^disk[0-9]+s[0-9]+$/ {
      id=$NF; size=$(NF-2)" "$(NF-1); type="";
      for (i=2; i<=NF-3; i++) type = type (type==""?"":" ") $i;
      print id "\t" size "\t" type
    }'
}

# A stable-ish identity for a device: "UUID|label|bytes". Used to detect when a
# saved diskN number now points at a *different* physical drive (replug drift).
device_identity() {
  local dev="$1" di uuid label bytes
  di="$(diskutil info "$dev" 2>/dev/null)" || return 1
  [[ -n "$di" ]] || return 1
  uuid="$(printf '%s\n' "$di" | awk -F': +' '/Volume UUID/{print $2; exit}')"
  [[ -n "$uuid" ]] || uuid="$(printf '%s\n' "$di" | awk -F': +' '/Partition UUID/{print $2; exit}')"
  label="$(printf '%s\n' "$di" | awk -F': +' '/Volume Name/{print $2; exit}')"
  bytes="$(printf '%s\n' "$di" | grep -oE '\([0-9]+ Bytes' | head -1 | grep -oE '[0-9]+')"
  printf '%s|%s|%s' "$uuid" "$label" "$bytes"
}

# A STRONG identity for pinning a device, printed on success. Requires a real
# discriminator so it can never collapse to a label+size-only string that
# collides across same-size external drives:
#   - a Volume/Partition UUID (first field of device_identity is non-empty), OR
#   - a boot-sector fingerprint (device_key: the BitLocker volume GUID / boot
#     sector hash) when no UUID is exposed (MBR / BitLocker-To-Go drives).
# Returns non-zero (printing nothing) if neither can be derived, so callers can
# refuse to persist a weak/empty identity.
strong_device_identity() {   # <device>
  local dev="$1" id uuid key
  id="$(device_identity "$dev" 2>/dev/null || true)"
  uuid="${id%%|*}"
  if [[ -n "$uuid" ]]; then printf '%s' "$id"; return 0; fi
  # No UUID exposed — anchor the identity to a boot-sector fingerprint instead.
  key="$(device_key "$dev" 2>/dev/null || true)"
  if [[ -n "$key" ]]; then printf '%s|%s' "$key" "$id"; return 0; fi
  return 1
}

# Canonicalize a device path to /dev/diskXsY form for consistent comparisons:
# strip a leading raw-device 'r' (/dev/rdiskXsY -> /dev/diskXsY) and any trailing
# slash. Whole-disk paths (/dev/diskX) are returned as-is; validate_cli_device
# rejects them. Keeping this separate means the host_mounted() double-mount check
# below can't be evaded by a path variant (rdisk / whole-disk).
canonical_device() {
  local d="${1#/dev/}"
  d="${d#r}"          # rdiskXsY -> diskXsY (raw char device alias)
  printf '/dev/%s' "$d"
}

# Is <device> one of the external physical partitions we enumerate for
# auto-detect? Returns 0/1 only (no output, no die) so callers control the error.
# This is what stops an internal disk or a stale/whole-disk path from an explicit
# CLI arg flowing straight into (rw) mount.
device_is_external_partition() {   # <device>
  local part="${1#/dev/}" ext p
  ext="$(list_external_partitions)"
  while IFS= read -r p; do [[ "$p" == "$part" ]] && return 0; done <<< "$ext"
  return 1
}

# Is <device> an EFI system partition? Uses the SAME type string that
# autodetect_device and the wizard classify on (the diskutil list TYPE column,
# which reads "EFI EFI System Partition"), so the explicit-path guards reject
# exactly what auto-detect refuses. EFI is FAT and would otherwise pass the
# 'external partition' + strong-identity checks and be rw-mountable, corrupting
# boot/EFI metadata. Returns 0 only when the row is positively typed EFI*.
device_is_efi() {   # <device>
  local want="${1#/dev/}" id type
  while IFS=$'\t' read -r id _ type; do
    [[ "$id" == "$want" ]] || continue
    [[ "$type" == EFI* ]] && return 0
    return 1
  done <<< "$(list_partition_rows)"
  return 1
}

# Is the device currently mounted by the macOS host?
host_mounted() { mount 2>/dev/null | grep -q "^/dev/${1#/dev/} "; }

# Release the macOS host mount before anylinuxfs touches the raw device. macOS
# auto-mounts exFAT/FAT read-WRITE (and NTFS read-only); two writers on one
# filesystem corrupts it. Only a NORMAL unmount is attempted — never a forced
# one: a forced unmount can drop another app's buffered writes and lose user
# data. If the volume stays busy the caller fails closed and asks the user to
# eject it themselves. Returns non-zero if the device is still host-mounted.
release_host_mount() {
  local dev="$1"
  host_mounted "$dev" || return 0
  info "$(t host.unmounting "$dev")"
  diskutil unmount "$dev" >/dev/null 2>&1 || true
  ! host_mounted "$dev"
}

# Auto-detect a mountable partition: prefer an encrypted one, else any
# filesystem anylinuxfs can mount. EFI system partitions are never candidates.
autodetect_device() {
  local rows enc=() mnt=() all=() id type fst
  rows="$(list_partition_rows)"
  [[ -n "$rows" ]] || { err "$(t det.nodisk)"; return 1; }

  sudo -v 2>/dev/null || true   # prime sudo so the signature reads succeed
  while IFS=$'\t' read -r id _ type; do
    [[ -n "$id" ]] || continue
    [[ "$type" == EFI* ]] && continue        # never auto-mount EFI system partitions
    all+=("/dev/$id")
    fst="$(fstype "$id")"
    fs_is_encrypted "$fst" && enc+=("/dev/$id")
    fs_is_mountable "$fst" && mnt+=("/dev/$id")
  done <<< "$rows"

  # prefer a single encrypted volume, else a single mountable volume
  if [[ ${#enc[@]} -eq 1 ]]; then printf '%s' "${enc[0]}"; return 0; fi
  if [[ ${#enc[@]} -gt 1 ]]; then err "$(t det.multi "${enc[*]}")"; err "$(t det.hintcfg)"; return 1; fi
  if [[ ${#mnt[@]} -eq 1 ]]; then printf '%s' "${mnt[0]}"; return 0; fi
  if [[ ${#mnt[@]} -gt 1 ]]; then err "$(t det.multi "${mnt[*]}")"; err "$(t det.hintcfg)"; return 1; fi

  # No recognized filesystem. Do NOT auto-mount an unclassified device — make
  # the user name it explicitly (perform_mount will then ask for confirmation).
  err "$(t det.cantauto "${all[*]:-N/A}")"
  err "$(t det.hintcfg2)"
  return 1
}

# Resolve the device to use: CLI arg > config DEVICE (identity-checked) > auto-detect
# Arg 2 (mode) is used to require a strong identity before an explicit rw mount.
resolve_device() {
  local arg="${1:-}" mode="${2:-ro}"
  if [[ -n "$arg" ]]; then
    # An explicit CLI device must clear the same bar as auto-detect/config —
    # never trust a raw path straight into (rw) mount. Reject whole-disk/internal
    # paths, require an external partition, and canonicalize (strip a raw-device
    # 'r') so the later host_mounted() double-mount check can't be dodged by a
    # /dev/rdiskXsY variant. For rw, additionally require a strong identity so a
    # stale disk number can't silently point a writer at a different drive.
    local dev
    dev="$(canonical_device "$arg")"
    # Must be an external PARTITION (diskXsY), never a whole disk (diskX),
    # internal disk, or raw path variant. Canonicalization above already stripped
    # a leading raw-device 'r' so the later host_mounted() double-mount check
    # can't be dodged by a /dev/rdiskXsY variant.
    [[ "$dev" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || die "$(t cfg.deverr)"
    device_is_external_partition "$dev" || die "$(t det.cantauto "$dev")"
    # Reject EFI system partitions here too — the external-partition check above
    # does NOT filter EFI, so an explicit `rw /dev/diskXs1` would otherwise flow
    # (EFI is FAT) straight into a rw mount and corrupt boot/EFI metadata. Apply
    # the same rejection auto-detect and the wizard use.
    device_is_efi "$dev" && die "$(t det.cantauto "$dev")"
    if [[ "$mode" == "rw" ]]; then
      # For rw, require a strong identity so a stale disk number can't silently
      # point a writer at a different drive.
      strong_device_identity "$dev" >/dev/null 2>&1 || die "$(t dev.weakid "$dev")"
    fi
    printf '%s' "$dev"; return 0
  fi
  if [[ -n "$DEVICE" ]]; then
    # Guard against diskN drift, FAIL CLOSED: a pinned DEVICE is only trusted
    # when we have a saved identity AND can recompute it AND it still matches.
    # A legacy config with DEVICE but no DEVICE_ID, or a diskutil read that
    # fails to recompute, must refuse — never silently operate on whatever disk
    # happens to occupy this path (that risks a rw mount hitting the wrong drive).
    if [[ -z "$DEVICE_ID" ]]; then
      die "$(t dev.noid "$DEVICE")"
    fi
    # Same external-partition guard applied to explicit CLI devices (above): a
    # pinned DEVICE must still be an external partition at use time, so an
    # internal / non-external / EFI partition can never be unmounted and (rw)
    # mounted by bltusb even when its identity matches.
    device_is_external_partition "$DEVICE" || die "$(t det.cantauto "$DEVICE")"
    # device_is_external_partition does NOT filter EFI (EFI is a FAT external
    # partition), so a legacy/hand-edited config whose DEVICE_ID still matches an
    # EFI system partition would otherwise flow into a rw mount and corrupt
    # boot/EFI metadata. Apply the same EFI rejection used on the explicit-CLI and
    # config-set paths.
    device_is_efi "$DEVICE" && die "$(t det.cantauto "$DEVICE")"
    local cur
    cur="$(strong_device_identity "$DEVICE" 2>/dev/null || true)"
    if [[ -z "$cur" ]]; then
      die "$(t dev.recompfail "$DEVICE")"
    fi
    if [[ "$cur" != "$DEVICE_ID" ]]; then
      die "$(t dev.mismatch "$DEVICE")"
    fi
    printf '%s' "$DEVICE"; return 0
  fi
  autodetect_device
}

# ---------------------------------------------------------------------------
# Mount state & core mount
# ---------------------------------------------------------------------------
current_mountpoint() {
  local mp
  mp="$(anylinuxfs status 2>/dev/null | grep -oE '/Volumes/[^ ]+' | head -1 || true)"
  # Defense in depth before it flows into `open`, `anylinuxfs unmount -w`, and cd
  # hints (all of which already quote it / consume it via %s): require a /Volumes
  # path and reject CONTROL characters — the real residual risk from a hostile or
  # garbled volume name is terminal-escape injection, not shell injection. We do
  # NOT restrict to ASCII: Unicode volume labels (e.g. /Volumes/备份) are valid
  # and an ASCII-only whitelist would wrongly report such drives as "not mounted".
  if [[ "$mp" != /Volumes/* || "$mp" == *[[:cntrl:]]* ]]; then mp=""; fi
  printf '%s' "$mp"
}
is_mounted() { [[ -n "$(current_mountpoint)" ]]; }

# Run `anylinuxfs mount`. The passphrase (arg 1) is handed to anylinuxfs via the
# ALFS_PASSPHRASE environment variable — anylinuxfs exposes no stdin/fd channel
# for the secret, so the env var is the only supported mechanism. Keeping it out
# of argv means it never shows in a plain `ps`; note that an env-aware listing
# (`ps -E`, or reading the child's environ) can still observe it for the brief
# lifetime of the mount subprocess. We therefore (a) scope the variable to just
# this one command (an inline `VAR=val cmd` assignment, never an exported/global
# that would leak into every later child), (b) pass it only when a passphrase is
# actually needed, and (c) never echo the value to any log — the info() lines
# print `--preserve-env=ALFS_PASSPHRASE` but never the passphrase itself.
# Remaining args are the mount options + dev.
run_mount() {
  local pass="$1"; shift
  # stdin from /dev/null: the mount must NOT consume our stdin, or it would eat
  # the answer to the follow-up "remember this drive?" prompt.
  if [[ -n "$pass" ]]; then
    ALFS_PASSPHRASE="$pass" sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount "$@" </dev/null
  else
    sudo anylinuxfs mount "$@" </dev/null
  fi
}

# perform_mount <device> <ro|rw> <do_open:true|false>
perform_mount() {
  local dev="$1" mode="$2" do_open="${3:-false}"

  sudo -v 2>/dev/null || true          # prime sudo (mounting needs root anyway)
  local fst; fst="$(fstype "$dev")"

  # Guard #1: never let anylinuxfs touch the raw device while macOS still has the
  # filesystem mounted. exFAT/FAT are host-mounted read-WRITE (two writers →
  # corruption); even NTFS/host-read-only mounts mean macOS may flush dirty
  # metadata (Spotlight, .DS_Store, FAT tables) while anylinuxfs reads the same
  # structures, yielding a torn/inconsistent view. Fail closed for BOTH rw and
  # ro rather than proceeding on top of a live host mount.
  if ! release_host_mount "$dev"; then
    warn "$(t host.busyforce)"
    die "$(t host.busy "$dev")"
  fi

  # Read-only options. For ext, add norecovery so a "read-only" mount can't
  # silently write via journal replay on a dirty volume.
  local opts=(-w false)
  if [[ "$mode" != "rw" ]]; then
    if [[ "$fst" == ext ]]; then opts+=(-o "ro,norecovery"); else opts+=(-o ro); fi
  fi

  step "$(t mnt.mounting "$dev" "$mode")"
  [[ "$mode" == "rw" ]] && warn "$(t mnt.rwwarn)"

  local rc=0
  if fs_is_encrypted "$fst"; then
    # Per-drive password: try this volume's own saved password (or env) first;
    # if it fails — re-encrypted transfer drive, locked/empty Keychain — fall
    # back to prompting and retry once. On success, offer to remember (opt-in).
    local key; key="$(device_key "$dev")"
    local qp; qp="$(get_passphrase_quiet "$key")"
    if [[ -n "$qp" ]]; then
      info "sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount ${opts[*]} ${dev}"
      run_mount "$qp" "${opts[@]}" "$dev" || rc=$?
      [[ $rc -ne 0 ]] && warn "$(t pass.savedfail)"
    else
      rc=1
    fi
    if [[ $rc -ne 0 ]] && ! is_mounted; then
      local pp; pp="$(prompt_passphrase_only)"
      info "sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount ${opts[*]} ${dev}"
      rc=0; run_mount "$pp" "${opts[@]}" "$dev" || rc=$?
      [[ $rc -eq 0 ]] && offer_save "$pp" "$key"
    fi
  elif fs_is_plain "$fst"; then
    info "${C_DIM}$(t mnt.noenc "$fst")${C_RESET}"
    info "sudo anylinuxfs mount ${opts[*]} ${dev}"
    run_mount "" "${opts[@]}" "$dev" || rc=$?
  else
    # Guard #5: unrecognized filesystem — never silently mount or auto-send a
    # stored password; require explicit confirmation.
    warn "$(t mnt.unknownfs "$fst")"
    printf '%s' "${C_CYN}$(t mnt.unknownask)${C_RESET}" >&2
    local uans; read -r uans
    case "${uans:-N}" in [yY]*) : ;; *) die "$(t mnt.cancelled2)" ;; esac
    info "sudo anylinuxfs mount ${opts[*]} ${dev}"
    run_mount "" "${opts[@]}" "$dev" || rc=$?
  fi

  if [[ $rc -eq 0 ]]; then
    local mp; mp="$(current_mountpoint)"
    ok "$(t mnt.success "${mp:+ → $mp}")  ${C_DIM}(${mode})${C_RESET}"
    [[ -n "$mp" ]] && printf '   %s\n' "${C_DIM}$(t mnt.cd "$mp")${C_RESET}"
    if [[ "$do_open" == "true" && -n "$mp" ]]; then open "$mp"; fi
    return 0
  else
    err "$(t mnt.fail)"
    err "$(t mnt.failhint)"
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Interactive wizard (default action when run with no arguments)
# ---------------------------------------------------------------------------
cmd_auto() {
  ensure_installed

  if is_mounted; then
    local mp; mp="$(current_mountpoint)"
    info "$(t wiz.mountedopen "$mp")"
    open "$mp"; ok "$(t open.done)"
    return 0
  fi

  step "$(t wiz.detecting)"
  sudo -v 2>/dev/null || true   # prime sudo so filesystem detection can read signatures
  local ids=() sizes=() types=() fsts=() rec=0 rec_enc=0 rec_any=0 n=0 id size type fst
  while IFS=$'\t' read -r id size type; do
    [[ -n "$id" ]] || continue
    # Never make the EFI system partition selectable: like autodetect_device,
    # exclude it from the list entirely so a user can't accidentally pick a FAT
    # EFI partition and rw-mount it (that partition must never be user-mounted).
    [[ "$type" == EFI* ]] && continue
    fst="$(fstype "$id")"
    ids+=("$id"); sizes+=("$size"); types+=("$type"); fsts+=("$fst")
    fs_is_encrypted "$fst" && [[ $rec_enc -eq 0 ]] && rec_enc=$((n+1))
    if fs_is_mountable "$fst" && [[ $rec_any -eq 0 ]]; then rec_any=$((n+1)); fi
    n=$((n+1))
  done <<< "$(list_partition_rows)"

  [[ $n -gt 0 ]] || { err "$(t wiz.none)"; return 1; }
  if [[ $rec_enc -gt 0 ]]; then rec=$rec_enc; elif [[ $rec_any -gt 0 ]]; then rec=$rec_any; else rec=1; fi

  local choice="$rec"
  if [[ $n -eq 1 ]]; then
    choice=1
    info "/dev/${ids[0]}  ${C_DIM}${sizes[0]}  ${fsts[0]}${C_RESET}"
  else
    echo; printf '%s\n' "$(t wiz.pick)"
    local i mark
    for ((i=0; i<n; i++)); do
      if fs_is_mountable "${fsts[$i]}"; then mark="${C_GRN}${fsts[$i]}${C_RESET}"; else mark="${C_DIM}${fsts[$i]}${C_RESET}"; fi
      fs_is_encrypted "${fsts[$i]}" && mark="$mark ${C_YEL}🔒${C_RESET}"
      [[ $((i+1)) -eq $rec ]] && mark="$mark ${C_DIM}($(t wiz.recommended))${C_RESET}"
      printf '  %s) %-12s %-9s %-16s %s\n' "$((i+1))" "/dev/${ids[$i]}" "${sizes[$i]}" "${types[$i]}" "$mark"
    done
    printf '%s' "$(t wiz.devask "$rec")"
    local ans; read -r ans
    [[ -n "$ans" ]] && choice="$ans"
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > n )); then die "$(t wiz.invalid)"; fi
  fi

  local sel="/dev/${ids[$((choice-1))]}"

  # Mode: default read-only
  echo; printf '%s\n' "$(t wiz.modehdr)"
  printf '  1) %s\n' "$(t wiz.modero)"
  printf '  2) %s\n' "$(t wiz.moderw)"
  printf '%s' "$(t wiz.modeask)"
  local mans mode="ro"; read -r mans
  [[ "$mans" == "2" ]] && mode="rw"

  # Route through resolve_device so the wizard's rw path gets the same
  # strong-device-identity gate as cmd_mount: a disk number that has drifted
  # after a replug must never silently point a read-write mount at a different
  # physical drive.
  local dev; dev="$(resolve_device "$sel" "$mode")" || return 1

  echo
  perform_mount "$dev" "$mode" "false" || return 1

  # Offer to open in Finder
  local mp; mp="$(current_mountpoint)"
  if [[ -n "$mp" ]]; then
    printf '%s' "$(t wiz.openask)"
    local oans; read -r oans
    case "${oans:-Y}" in [nN]*) : ;; *) open "$mp"; ok "$(t open.done)" ;; esac
  fi
  [[ "$mode" == "ro" ]] && info "${C_DIM}$(t wiz.rwhint)${C_RESET}"
}

# ---------------------------------------------------------------------------
# Commands: mount / rw / umount / status / detect / open
# ---------------------------------------------------------------------------
cmd_mount() {
  local mode="$DEFAULT_MODE" dev_arg="" do_open="false" a
  for a in "$@"; do
    case "$a" in
      ro|readonly) mode="ro" ;;
      rw|readwrite) mode="rw" ;;
      --open) do_open="true" ;;
      /dev/*) dev_arg="$a" ;;
      disk*) dev_arg="/dev/$a" ;;
      *) warn "ignoring unknown arg: $a" ;;
    esac
  done

  ensure_installed

  if is_mounted; then
    warn "$(t mnt.already "$(current_mountpoint)")"
    warn "$(t mnt.switchhint)"
    return 0
  fi

  local dev; dev="$(resolve_device "$dev_arg" "$mode")" || exit 1
  perform_mount "$dev" "$mode" "$do_open" || exit 1
}

cmd_rw() { cmd_mount rw "$@"; }

cmd_umount() {
  if ! is_mounted; then
    info "$(t umt.none)"
    return 0
  fi
  local mp; mp="$(current_mountpoint)"
  step "$(t umt.unmounting "$mp")"
  sync 2>/dev/null || true            # flush host dirty pages to the VM first
  # -w waits for the microVM to fully exit (finish flushing to the USB) before returning.
  # Pass the captured mountpoint so ONLY this volume is torn down: a bare
  # `anylinuxfs unmount` unmounts ALL anylinuxfs mounts and could interrupt a
  # second, actively-flushing rw mount (data-loss path).
  if sudo anylinuxfs unmount -w "$mp"; then
    ok "$(t umt.done)"
    ok "$(t umt.saferemove)"
  else
    err "$(t umt.fail)"
    exit 1
  fi
}

cmd_status() {
  ensure_installed
  step "$(t st.header)"
  local out; out="$(anylinuxfs status 2>/dev/null || true)"
  if [[ -n "$out" ]]; then
    printf '%s\n' "$out"
    local mp; mp="$(current_mountpoint)"
    [[ -n "$mp" ]] && ok "$(t st.mounted "$mp")"
  else
    info "$(t st.none)"
  fi
  echo
  step "$(t st.extdisks)"
  diskutil list external physical 2>/dev/null || info "$(t st.noext)"
}

cmd_detect() {
  step "$(t det.header)"
  sudo -v 2>/dev/null || true
  local parts p fst any="false"
  parts="$(list_external_partitions)"
  [[ -n "$parts" ]] || { info "$(t det.nopart)"; return 0; }
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    fst="$(fstype "$p")"
    if fs_is_mountable "$fst"; then
      any="true"
      if fs_is_encrypted "$fst"; then
        ok "${C_GRN}/dev/$p${C_RESET}  ${C_BOLD}$fst${C_RESET}  ${C_YEL}🔒 $(t fs.encrypted)${C_RESET}"
      else
        ok "${C_GRN}/dev/$p${C_RESET}  ${C_BOLD}$fst${C_RESET}"
      fi
    else
      printf '   %s\n' "${C_DIM}/dev/$p  $fst${C_RESET}"
    fi
  done <<< "$parts"
  [[ "$any" == "true" ]] || warn "$(t det.noconfirm)"
}

cmd_open() {
  if is_mounted; then
    open "$(current_mountpoint)"; ok "$(t open.done)"
  else
    cmd_mount --open "$@"
  fi
}

# ---------------------------------------------------------------------------
# Command: config
# ---------------------------------------------------------------------------
cmd_config() {
  local sub="${1:-show}"; shift || true
  case "$sub" in
    show|"")
      step "$(t cfg.header)"
      printf '  %-9s: %s\n' "$(t cfg.file)"   "$CONFIG_FILE"
      printf '  %-9s: %s\n' "$(t cfg.device)" "${DEVICE:-$(t cfg.auto)}"
      printf '  %-9s: %s\n' "$(t cfg.mode)"   "$DEFAULT_MODE"
      printf '  %-9s: %s\n' "$(t cfg.lang)"   "$(lang_name "$BLTUSB_LANG_CODE")"
      printf '  %-9s: %s\n' "$(t cfg.password)" "${C_DIM}$(t cfg.pass.perdrive)${C_RESET}"
      ;;
    set-device|device)
      local d="${1:-}"
      [[ -n "$d" ]] || { printf '%s' "$(t cfg.devprompt)"; read -r d; }
      if [[ -n "$d" && ! "$d" =~ ^/dev/disk[0-9]+s[0-9]+$ ]]; then die "$(t cfg.deverr)"; fi
      if [[ -n "$d" ]]; then
        # Never pin a non-external partition (internal disk / EFI / stale path):
        # match the guard applied on the explicit-CLI and pinned mount paths so a
        # dangerous device can't be persisted and later (rw) mounted.
        device_is_external_partition "$d" || die "$(t det.cantauto "$d")"
        # Never pin an EFI system partition: external_partition does not filter
        # EFI, so without this a pinned EFI (FAT) could later be (rw) mounted and
        # corrupt boot/EFI metadata. Same rejection as auto-detect / the wizard.
        device_is_efi "$d" && die "$(t det.cantauto "$d")"
        # Require a STRONG identity (UUID or boot-sector fingerprint) before we
        # pin a device — never persist an empty or label+size-only identity, or
        # the drift guard in resolve_device would be silently disabled.
        DEVICE_ID="$(strong_device_identity "$d" 2>/dev/null || true)"
        [[ -n "$DEVICE_ID" ]] || die "$(t dev.weakid "$d")"
      else
        DEVICE_ID=""   # empty DEVICE = auto-detect each time; no identity to pin
      fi
      DEVICE="$d"
      save_config
      ;;
    set-mode|mode)
      local m="${1:-}"
      case "$m" in ro|rw) DEFAULT_MODE="$m"; save_config ;; *) die "$(t cfg.modeerr)" ;; esac
      ;;
    init)
      step "$(t cfg.init.header)"
      printf '%s' "$(t cfg.init.dev)"; read -r DEVICE
      if [[ -n "$DEVICE" ]]; then
        if [[ ! "$DEVICE" =~ ^/dev/disk[0-9]+s[0-9]+$ ]]; then die "$(t cfg.deverr)"; fi
        # Never pin a non-external partition (internal / EFI / stale path):
        # match the mount-path guard so a dangerous device can't be persisted.
        device_is_external_partition "$DEVICE" || die "$(t det.cantauto "$DEVICE")"
        # Never pin an EFI system partition (external_partition does not filter
        # EFI, and EFI is FAT so it would otherwise be rw-mountable): reject it
        # the same way auto-detect and the wizard do before persisting.
        device_is_efi "$DEVICE" && die "$(t det.cantauto "$DEVICE")"
        # Require a strong identity to pin the device; abort rather than persist
        # an empty/weak one that would disable the diskN-drift guard.
        DEVICE_ID="$(strong_device_identity "$DEVICE" 2>/dev/null || true)"
        [[ -n "$DEVICE_ID" ]] || die "$(t dev.weakid "$DEVICE")"
      else
        DEVICE_ID=""
      fi
      printf '%s' "$(t cfg.init.mode)"; local m; read -r m
      if [[ "$m" == "rw" ]]; then DEFAULT_MODE="rw"; else DEFAULT_MODE="ro"; fi
      save_config
      ;;
    *) die "$(t cfg.unknownsub "$sub")" ;;
  esac
}

# ---------------------------------------------------------------------------
# Command: forget — remove a saved per-drive password (opt-in cleanup)
# ---------------------------------------------------------------------------
cmd_forget() {
  local arg="${1:-}"
  # Prime sudo before device_key: on a cold terminal an MBR/BitLocker-To-Go drive
  # has no Partition UUID, so device_key falls back to a `sudo -n dd` boot-sector
  # read. Without a warm sudo timestamp that read fails, device_key now returns
  # empty, and forget would report "no saved password" while leaving the real
  # per-device Keychain entry behind. Priming makes the fingerprint reproducible.
  sudo -v 2>/dev/null || true
  case "$arg" in
    --all)
      printf '%s' "${C_YEL}$(t forget.allask)${C_RESET}" >&2
      local ans; read -r ans
      case "${ans:-N}" in
        [yY]*)
          while security delete-generic-password -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1; do :; done
          ok "$(t forget.alldone)"
          ;;
        *) info "$(t mnt.cancelled2)" ;;
      esac
      ;;
    /dev/*|disk*)
      local dev="$arg"; [[ "$arg" == disk* ]] && dev="/dev/$arg"
      local key; key="$(device_key "$dev")"
      [[ -n "$key" ]] || die "$(t forget.none "$dev")"
      if [[ -n "$(keychain_get "$key")" ]]; then keychain_del "$key"; ok "$(t forget.done "$dev")"; else info "$(t forget.none "$dev")"; fi
      ;;
    ""|*) die "$(t forget.usage)" ;;
  esac
}

# ---------------------------------------------------------------------------
# Command: lang
# ---------------------------------------------------------------------------
cmd_lang() {
  local sub="${1:-show}"
  case "$sub" in
    show|"")
      step "$(t lang.header)"
      printf '  %-12s: %s %s\n' "$(t lang.effective)" "$(lang_name "$BLTUSB_LANG_CODE")" "${C_DIM}($BLTUSB_LANG_CODE)${C_RESET}"
      if [[ -n "$LANG_OVERRIDE" ]]; then
        printf '  %-12s: %s\n' "$(t lang.override)" "$(lang_name "$LANG_OVERRIDE")"
      else
        printf '  %-12s: %s\n' "$(t lang.override)" "${C_DIM}$(t lang.auto)${C_RESET}"
      fi
      ;;
    en|zh-CN|zh-TW)
      LANG_OVERRIDE="$sub"; save_config
      BLTUSB_LANG_CODE="$sub"
      ok "$(t lang.set "$(lang_name "$sub")")"
      ;;
    auto)
      LANG_OVERRIDE=""; save_config
      BLTUSB_LANG_CODE="$(resolve_lang)"
      ok "$(t lang.reset)"
      ;;
    *) die "$(t lang.unknown "$sub")" ;;
  esac
}

