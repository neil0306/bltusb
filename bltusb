# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  load_config
  validate_config
  BLTUSB_LANG_CODE="$(resolve_lang)"
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    "")                   cmd_auto ;;
    install)              cmd_install "$@" ;;
    mount|m)              cmd_mount "$@" ;;
    rw)                   cmd_rw "$@" ;;
    open)                 cmd_open "$@" ;;
    umount|unmount|u)     cmd_umount "$@" ;;
    status|st)            cmd_status "$@" ;;
    detect)               cmd_detect "$@" ;;
    config|cfg)           cmd_config "$@" ;;
    lang|language)        cmd_lang "$@" ;;
    version|-v|--version) printf 'bltusb %s\n' "$VERSION" ;;
    help|-h|--help)       cmd_help ;;
    *) err "$(t main.unknown "$cmd")"; echo; cmd_help; exit 1 ;;
  esac
}
main "$@"
