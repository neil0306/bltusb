    vm.up.verifyfail) en="Rebuilt, but 'anylinuxfs image list' does not yet show bltusb-min — check the build output above"; zh_cn="已重新构建，但 'anylinuxfs image list' 尚未列出 bltusb-min —— 请检查上方构建输出"; zh_tw="已重新建置，但 'anylinuxfs image list' 尚未列出 bltusb-min —— 請檢查上方建置輸出" ;;
    vm.st.header)     en="bltusb vm (bltusb-min microVM) status"; zh_cn="bltusb vm（bltusb-min microVM）状态"; zh_tw="bltusb vm（bltusb-min microVM）狀態" ;;
    vm.st.built)      en="Built"; zh_cn="已构建"; zh_tw="已建置" ;;
    vm.st.digest)     en="Pinned digest"; zh_cn="固定 digest"; zh_tw="固定 digest" ;;
    vm.st.drivers)    en="Driver binaries"; zh_cn="驱动程序"; zh_tw="驅動程式" ;;
    vm.st.notbuilt)   en="not built (run: bltusb vm build)"; zh_cn="未构建（运行：bltusb vm build）"; zh_tw="未建置（執行：bltusb vm build）" ;;
    vm.st.present)    en="yes"; zh_cn="是"; zh_tw="是" ;;
    vm.st.absent)     en="no"; zh_cn="否"; zh_tw="否" ;;
    vm.st.none)       en="(none)"; zh_cn="（无）"; zh_tw="（無）" ;;
    *)                en="$k"; zh_cn="$k"; zh_tw="$k" ;;
  esac
  case "$BLTUSB_LANG_CODE" in
    en)    m="$en" ;;
    zh-TW) m="$zh_tw" ;;
    *)     m="$zh_cn" ;;
  esac
  # SC2059 (variable format string) is intentional and safe here: $m is never
  # attacker-controlled — it is one of the hard-coded en/zh translation literals
  # selected by $k above. All external/untrusted values (device paths, mount
  # points, labels) arrive only as "$@" and are consumed strictly through the
  # translations' %s conversions, so they are substituted as data and never
  # re-interpreted as a printf format. (current_mountpoint() additionally
  # whitelists the one path that reaches a %s from `anylinuxfs status`.)
  # shellcheck disable=SC2059
  printf "$m" "$@"
}

# ---------------------------------------------------------------------------
# Config load/save
# ---------------------------------------------------------------------------
# Parse the config WITHOUT `source` so a hand-edited/crafted config can never
# execute code. Only known keys are honored; values are validated in main().
load_config() {
  [[ -f "$CONFIG_FILE" ]] || return 0
  local line key val
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"; val="${line#*=}"
    val="${val%\"}"; val="${val#\"}"   # strip one layer of surrounding quotes
    case "$key" in
      DEVICE)        DEVICE="$val" ;;
      DEVICE_ID)     DEVICE_ID="$val" ;;
      DEFAULT_MODE)  DEFAULT_MODE="$val" ;;
      LANG_OVERRIDE) LANG_OVERRIDE="$val" ;;
      AUTOUNLOCK)    AUTOUNLOCK="$val" ;;
      AUTOUNLOCK_VIA) AUTOUNLOCK_VIA="$val" ;;
    esac
  done < "$CONFIG_FILE"
}

# Reject anything untrusted read from the config file (fail closed).
validate_config() {
  case "$DEFAULT_MODE" in ro|rw) ;; *) DEFAULT_MODE="ro" ;; esac
  case "$LANG_OVERRIDE" in ""|en|zh-CN|zh-TW) ;; *) LANG_OVERRIDE="" ;; esac
  case "$AUTOUNLOCK" in on|off) ;; *) AUTOUNLOCK="off" ;; esac
  # Empty = "not recorded" (an old config without the key) → callers detect it.
  # A malformed non-empty value is fail-closed to empty (never trusted).
  case "$AUTOUNLOCK_VIA" in self|brew|"") ;; *) AUTOUNLOCK_VIA="" ;; esac
  [[ -z "$DEVICE" || "$DEVICE" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || DEVICE=""
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
# bltusb config — generated by \`bltusb config\` / \`bltusb lang\`, editable by hand
# DEVICE        : target partition, e.g. /dev/disk4s1; empty = auto-detect
# DEVICE_ID     : saved drive identity (UUID|label|bytes) — verified before use so a
#                 replug that shifts diskN numbers can't make bltusb touch a different disk
# DEFAULT_MODE  : default mount mode, ro (read-only, recommended) or rw (read-write)
# LANG_OVERRIDE : menu language, empty = follow system; en / zh-CN / zh-TW
# AUTOUNLOCK    : auto-mount external drives (read-only) on insert, on / off (default off)
# AUTOUNLOCK_VIA: mechanism running the auto-unlock daemon, self / brew (default self)
#                 self = self-managed per-user LaunchAgent; brew = via \`brew services\`
DEVICE="${DEVICE}"
DEVICE_ID="${DEVICE_ID}"
DEFAULT_MODE="${DEFAULT_MODE}"
LANG_OVERRIDE="${LANG_OVERRIDE}"
AUTOUNLOCK="${AUTOUNLOCK}"
AUTOUNLOCK_VIA="${AUTOUNLOCK_VIA}"
EOF
  ok "$(t cfg.saved "${C_DIM}${CONFIG_FILE}${C_RESET}")"
}

# ---------------------------------------------------------------------------
# Password (stored PER DRIVE in the macOS Keychain)
# ---------------------------------------------------------------------------
# Each encrypted volume gets its own Keychain item keyed by a stable per-volume
# identity, so N drives with different passwords never overwrite each other.
# keychain_* take the account (device key) as an argument.
keychain_get() {   # <account>
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" -w 2>/dev/null || true
}
keychain_set() {   # <password> <account>
  # Feed the password on stdin instead of on argv: `-w` with NO value makes
  # `security` read the secret interactively, so the plaintext never appears in
  # the process argv where a concurrent `ps` could read it. The interactive form
  # prompts for the password twice (enter + confirm), so send it on two lines.
  printf '%s\n%s\n' "$1" "$1" \
    | security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$2" -w >/dev/null 2>&1
}
keychain_del() {   # <account>
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" >/dev/null 2>&1 || true
}

# A stable Keychain account for a specific volume. GPT partitions have a
# Partition UUID; MBR/BitLocker-To-Go drives don't, so fall back to a
# fingerprint of the boot sector (contains the BitLocker volume GUID; stable
# across replug, changes only on re-encryption — which is the desired reset).
device_key() {
  local dev="$1" uuid b64 fp
  uuid="$(diskutil info "$dev" 2>/dev/null | awk -F': +' '/Partition UUID/{print $2; exit}')"
  if [[ -n "$uuid" ]]; then printf 'puuid:%s' "$uuid"; return 0; fi
  # No UUID — fall back to a boot-sector fingerprint. Do NOT stage the sector in a
  # temp file: a `mktemp` path is predictable enough that an attacker can swap it
  # for a symlink between create and write, redirecting root's `dd of=...` onto an
  # arbitrary file (classic symlink TOCTOU). Instead carry the sector through a
  # pipe. The sector contains NUL bytes, which command substitution strips, so
  # base64-encode it in the pipeline (base64 in a shell variable is NUL-safe) and
  # require EXACTLY 512 raw bytes — i.e. 684 base64 chars — before hashing. A cold
  # `sudo -n` (or a short read) yields zero/short output, whose length check fails.
  # Hashing an empty read would otherwise mint a non-empty but bogus, shared key
  # that collides across every drive whose read failed — breaking per-volume
  # identity and silently no-op'ing `forget`. Emit nothing (return 1) so callers
  # that test `[[ -n "$key" ]]` correctly treat a failed read as "no stable
  # identity". The hash is over the DECODED 512 raw bytes, so the fingerprint is
  # byte-identical to a direct `dd | shasum` (and to the test's dev_key()).
  b64="$(sudo -n dd if="/dev/r${dev#/dev/}" bs=512 count=1 2>/dev/null | base64 2>/dev/null | tr -d '\n')"
  [[ ${#b64} -eq 684 ]] || return 1
  fp="$(printf '%s' "$b64" | base64 -d 2>/dev/null | shasum -a 256 | cut -c1-32)"
  [[ -n "$fp" ]] && printf 'fp:%s' "$fp"
}

# 48-digit BitLocker recovery key (8 groups of 6 digits)? Accept both the
# hyphenated form (######-######-…) and 48 contiguous digits with no
# separators — the prompt tells users to enter a "48-digit recovery key", so a
# pasted un-hyphenated key must be recognized too and never offered for saving.
is_recovery_key() { [[ "$1" =~ ^[0-9]{6}(-[0-9]{6}){7}$ || "$1" =~ ^[0-9]{48}$ ]]; }

# Non-interactive password for THIS volume: env ALFS_PASSPHRASE first, else this
# drive's OWN per-device Keychain item, else — as a MIGRATION fallback, and only
# when this drive has no per-device item yet — the legacy single global item (see
# below). That fallback lets users upgrading from the pre-per-device version keep
# working. NOTE: a successful mount using the legacy item does NOT auto-write a
# per-device item — offer_save() runs only on the interactive re-prompt path
# (perform_mount), never on this quiet path — so the global item stays the source
# for this drive until the user saves a per-device credential (i.e. only if the
# stored value later fails, they re-enter, and accept saving). It is NOT a
# cross-drive secret leak: anylinuxfs is a local decryptor, so a value that
# doesn't fit the current volume simply falls through to the re-prompt path.
# Arg 1 = device key (may be empty). The password is printed to stdout (captured
# by the caller); any human-facing note goes to stderr so it never contaminates
# the returned secret.
get_passphrase_quiet() {   # <device_key>
  if [[ -n "${ALFS_PASSPHRASE:-}" ]]; then
    info "${C_DIM}$(t pass.envnote)${C_RESET}" >&2
    printf '%s' "$ALFS_PASSPHRASE"; return 0
  fi
  local p=""
  [[ -n "$1" ]] && p="$(keychain_get "$1")"
  # Migration fallback: older versions stored ONE global item. Consult it only as
  # a last resort (this drive has no per-device item yet) so existing users keep
  # working after upgrade. This quiet path does NOT save a per-device item on
  # success (offer_save runs only on the interactive re-prompt path), so the
  # global item stays this drive's source until it fails and the user re-enters
  # and accepts saving. Not a cross-drive leak: anylinuxfs is a local decryptor,
  # and a value that doesn't fit this drive simply falls through to the re-prompt.
  [[ -z "$p" ]] && p="$(keychain_get "$KEYCHAIN_ACCOUNT")"
  printf '%s' "$p"
}

# Prompt for the passphrase (or recovery key). Does NOT save — saving is offered
# separately, only after a successful mount (opt-in).
prompt_passphrase_only() {
  printf '%s' "${C_CYN}$(t pass.prompt)${C_RESET}" >&2
  # Clear IFS so leading/trailing whitespace in the password is preserved
  # byte-for-byte — the default IFS would trim it, breaking valid BitLocker
  # passwords that begin or end with spaces.
  local pw; IFS= read -rs pw; printf '\n' >&2
  [[ -n "$pw" ]] || die "$(t pass.empty)"
  printf '%s' "$pw"
}

# After a successful unlock, offer to remember THIS drive's password (default No).
# Recovery keys are never stored. Needs a stable device key.
offer_save() {   # <password> <device_key>
  [[ -n "$2" ]] || return 0
  if is_recovery_key "$1"; then info "${C_DIM}$(t pass.rknosave)${C_RESET}"; return 0; fi
  printf '%s' "${C_CYN}$(t pass.savekey)${C_RESET}" >&2
  local ans; read -r ans
  case "${ans:-N}" in [yY]*) keychain_set "$1" "$2" && ok "$(t cfg.pwsaved)" ;; *) : ;; esac
}

# ---------------------------------------------------------------------------
# Dependency check / install
# ---------------------------------------------------------------------------
have_anylinuxfs() { command -v anylinuxfs >/dev/null 2>&1; }

ensure_installed() {
  have_anylinuxfs && return 0
  warn "$(t inst.notfound)"
  printf '%s' "$(t inst.ask)" >&2
  local ans; read -r ans
  case "${ans:-Y}" in
    [nN]*) die "$(t inst.cancelled)" ;;
    *) cmd_install ;;
  esac
}

cmd_install() {
  step "$(t inst.header)"
  command -v brew >/dev/null 2>&1 || die "$(t inst.nobrew)"
  if have_anylinuxfs; then
    ok "$(t inst.already "$(anylinuxfs --version 2>/dev/null || echo ready)")"
    return 0
  fi
  info "brew tap nohajc/anylinuxfs"
  brew tap nohajc/anylinuxfs
  info "brew trust nohajc/anylinuxfs  ${C_DIM}# $(t inst.trustnote)${C_RESET}"
  brew trust nohajc/anylinuxfs || die "$(t inst.trustfail)"
  info "brew install anylinuxfs"
  brew install anylinuxfs
  if have_anylinuxfs; then ok "$(t inst.done)"; else die "$(t inst.missing)"; fi
}

# ---------------------------------------------------------------------------
# Device detection
# ---------------------------------------------------------------------------
# Read <count> bytes at absolute byte <offset> from a raw device. Raw char
# devices require sector-aligned reads, so read the containing 512B sector and
# then slice (a bare `dd bs=1 skip=N` on /dev/rdiskN fails with "Invalid
# argument"). Needs sudo.
_devbytes() {
  local dev="${1#/dev/}" off="$2" cnt="$3" sec rem
  sec=$(( off / 512 )); rem=$(( off % 512 ))
  sudo -n dd if="/dev/r${dev}" bs=512 count=1 skip="$sec" 2>/dev/null \
    | dd bs=1 skip="$rem" count="$cnt" 2>/dev/null
}

# Classify a partition's filesystem from its on-disk signatures.
# Echoes one of: bitlocker luks ntfs exfat fat ext apfs unknown
fstype() {
  local dev="$1" oem
  # Every read is non-fatal (|| true): a failed sudo/dd must yield "unknown",
  # never abort the script under `set -euo pipefail`.
  oem="$(_devbytes "$dev" 3 8 | LC_ALL=C tr -d '\000' || true)"
  case "$oem" in
    "$BITLOCKER_SIGNATURE") echo bitlocker; return ;;
    NTFS*)                  echo ntfs;  return ;;
    EXFAT*)                 echo exfat; return ;;
  esac
  [[ "$(_devbytes "$dev" 0 4 | LC_ALL=C tr -d '\000' || true)" == "LUKS" ]] && { echo luks; return; }
  case "$(_devbytes "$dev" 82 8 | LC_ALL=C tr -d '\000' || true)" in FAT32*) echo fat; return ;; esac
  case "$(_devbytes "$dev" 54 8 | LC_ALL=C tr -d '\000' || true)" in FAT12*|FAT16*) echo fat; return ;; esac
  [[ "$(_devbytes "$dev" 32 4 | LC_ALL=C tr -d '\000' || true)" == "NXSB" ]] && { echo apfs; return; }
  [[ "$(_devbytes "$dev" 1080 2 | xxd -p 2>/dev/null || true)" == "53ef" ]] && { echo ext; return; }
  echo unknown
}

# Does this filesystem need a passphrase to unlock?
fs_is_encrypted() { case "$1" in bitlocker|luks) return 0 ;; *) return 1 ;; esac; }
# A known, plain (non-encrypted) filesystem we can mount without a password.
fs_is_plain()     { case "$1" in ntfs|exfat|ext|fat) return 0 ;; *) return 1 ;; esac; }
# Is this a filesystem anylinuxfs can mount for us?
fs_is_mountable() { case "$1" in bitlocker|luks|ntfs|exfat|ext|fat) return 0 ;; *) return 1 ;; esac; }

# Heuristic: does the partition type look like a Windows/BitLocker volume?
looks_windows() {
  case "$1" in
    *Windows*|*Microsoft*|*NTFS*|*BitLocker*|*FAT*) return 0 ;;
    *) return 1 ;;
  esac
}

# Strip terminal-control and bidi-formatting codepoints from any backend/media-
# derived text (diskutil / anylinuxfs output, volume labels, device names) before
# it reaches the terminal, so a crafted USB volume label cannot inject ANSI/OSC
# escape sequences or bidi spoofing (Trojan-Source, CVE-2021-42574) into our
# output. Removed: C0 controls (keeping TAB/NEWLINE), DEL, C1 controls (U+0080–
# U+009F), and the true bidi controls U+061C (ALM), U+200E/U+200F (LRM/RLM),
# U+202A–U+202E (embeddings/overrides), U+2066–U+2069 (isolates). Deliberately
# NOT removed: U+200C/U+200D (ZWNJ/ZWJ) — legitimate in Arabic/Indic text and in
# emoji ZWJ sequences (e.g. 👨‍👩) — and U+200B, which is not a bidi/escape vector.
# UTF-8-safe: each line is decoded to Unicode codepoints with Encode::FB_DEFAULT,
# which substitutes malformed sequences from hostile media with U+FFFD (never
# fatal, no warnings) — so multibyte labels (e.g. 备份) survive intact, C1
# *codepoints* are matched (not UTF-8 continuation bytes), and a single bad byte
# can never blank a whole line/row. (A plain codepoint-range regex over an
# undecoded :utf8 stream would empty the line on malformed input — avoided here.)
# If perl is missing, fall back to a byte-safe C0/DEL strip that never touches
# bytes >= 0x80, so it cannot mangle UTF-8 (bidi controls survive that fallback,
# but escape-injection — the primary threat — is still neutralised).
sanitize_display() {
  if command -v perl >/dev/null 2>&1; then
    perl -pe 'BEGIN{binmode STDIN,":raw";binmode STDOUT,":raw";require Encode} $_=Encode::decode("UTF-8",$_,Encode::FB_DEFAULT); s/[\x00-\x08\x0B-\x1F\x7F\x{0080}-\x{009F}\x{061C}\x{200E}\x{200F}\x{202A}-\x{202E}\x{2066}-\x{2069}]//g; $_=Encode::encode("UTF-8",$_)' 2>/dev/null
  else
    LC_ALL=C tr -d '\000-\010\013-\037\177'
  fi
}

# List partition identifiers (diskNsM) on all external physical disks
list_external_partitions() {
  diskutil list external physical 2>/dev/null \
    | grep -oE 'disk[0-9]+s[0-9]+' | sort -u
}

# Emit one row per external partition: "id<TAB>size<TAB>type"
list_partition_rows() {
  diskutil list external physical 2>/dev/null | awk '
    /^ +[0-9]+:/ && $NF ~ /^disk[0-9]+s[0-9]+$/ {
      id=$NF; size=$(NF-2)" "$(NF-1); type="";
      for (i=2; i<=NF-3; i++) type = type (type==""?"":" ") $i;
      print id "\t" size "\t" type
    }'
}

# A stable-ish identity for a device: "UUID|label|bytes". Used to detect when a
# saved diskN number now points at a *different* physical drive (replug drift).
device_identity() {
  local dev="$1" di uuid label bytes
  di="$(diskutil info "$dev" 2>/dev/null)" || return 1
  [[ -n "$di" ]] || return 1
  uuid="$(printf '%s\n' "$di" | awk -F': +' '/Volume UUID/{print $2; exit}')"
  [[ -n "$uuid" ]] || uuid="$(printf '%s\n' "$di" | awk -F': +' '/Partition UUID/{print $2; exit}')"
  label="$(printf '%s\n' "$di" | awk -F': +' '/Volume Name/{print $2; exit}')"
  bytes="$(printf '%s\n' "$di" | grep -oE '\([0-9]+ Bytes' | head -1 | grep -oE '[0-9]+')"
  printf '%s|%s|%s' "$uuid" "$label" "$bytes"
}

# A STRONG identity for pinning a device, printed on success. Requires a real
# discriminator so it can never collapse to a label+size-only string that
# collides across same-size external drives:
#   - a Volume/Partition UUID (first field of device_identity is non-empty), OR
#   - a boot-sector fingerprint (device_key: the BitLocker volume GUID / boot
#     sector hash) when no UUID is exposed (MBR / BitLocker-To-Go drives).
# Returns non-zero (printing nothing) if neither can be derived, so callers can
# refuse to persist a weak/empty identity.
strong_device_identity() {   # <device>
  local dev="$1" id uuid key
  id="$(device_identity "$dev" 2>/dev/null || true)"
  uuid="${id%%|*}"
  if [[ -n "$uuid" ]]; then printf '%s' "$id"; return 0; fi
  # No UUID exposed — anchor the identity to a boot-sector fingerprint instead.
  key="$(device_key "$dev" 2>/dev/null || true)"
  if [[ -n "$key" ]]; then printf '%s|%s' "$key" "$id"; return 0; fi
  return 1
}

# Canonicalize a device path to /dev/diskXsY form for consistent comparisons:
# strip a leading raw-device 'r' (/dev/rdiskXsY -> /dev/diskXsY) and any trailing
# slash. Whole-disk paths (/dev/diskX) are returned as-is; validate_cli_device
# rejects them. Keeping this separate means the host_mounted() double-mount check
# below can't be evaded by a path variant (rdisk / whole-disk).
canonical_device() {
  local d="${1#/dev/}"
  d="${d#r}"          # rdiskXsY -> diskXsY (raw char device alias)
  printf '/dev/%s' "$d"
}

# Is <device> one of the external physical partitions we enumerate for
# auto-detect? Returns 0/1 only (no output, no die) so callers control the error.
# This is what stops an internal disk or a stale/whole-disk path from an explicit
# CLI arg flowing straight into (rw) mount.
device_is_external_partition() {   # <device>
  local part="${1#/dev/}" ext p
  ext="$(list_external_partitions)"
  while IFS= read -r p; do [[ "$p" == "$part" ]] && return 0; done <<< "$ext"
  return 1
}

# Is <device> an EFI system partition? Uses the SAME type string that
# autodetect_device and the wizard classify on (the diskutil list TYPE column,
# which reads "EFI EFI System Partition"), so the explicit-path guards reject
# exactly what auto-detect refuses. EFI is FAT and would otherwise pass the
# 'external partition' + strong-identity checks and be rw-mountable, corrupting
# boot/EFI metadata. Returns 0 only when the row is positively typed EFI*.
device_is_efi() {   # <device>
  local want="${1#/dev/}" id type
  while IFS=$'\t' read -r id _ type; do
    [[ "$id" == "$want" ]] || continue
    [[ "$type" == EFI* ]] && return 0
    return 1
  done <<< "$(list_partition_rows)"
  return 1
}

# Is the device currently mounted by the macOS host? Exact field compare (awk),
# not a grep regex: a device string is data, never a pattern — so a name with a
# regex metacharacter can't make the host-unmount (double-writer) guard misfire.
host_mounted() { mount 2>/dev/null | awk -v d="/dev/${1#/dev/}" '$1==d{f=1} END{exit !f}'; }

# Release the macOS host mount before anylinuxfs touches the raw device. macOS
# auto-mounts exFAT/FAT read-WRITE (and NTFS read-only); two writers on one
# filesystem corrupts it. Only a NORMAL unmount is attempted — never a forced
# one: a forced unmount can drop another app's buffered writes and lose user
# data. If the volume stays busy the caller fails closed and asks the user to
# eject it themselves. Returns non-zero if the device is still host-mounted.
release_host_mount() {
  local dev="$1"
  host_mounted "$dev" || return 0
  info "$(t host.unmounting "$dev")"
  diskutil unmount "$dev" >/dev/null 2>&1 || true
  ! host_mounted "$dev"
}

# Auto-detect a mountable partition: prefer an encrypted one, else any
# filesystem anylinuxfs can mount. EFI system partitions are never candidates.
autodetect_device() {
  local rows enc=() mnt=() all=() id type fst
  rows="$(list_partition_rows)"
  [[ -n "$rows" ]] || { err "$(t det.nodisk)"; return 1; }

  sudo -v 2>/dev/null || true   # prime sudo so the signature reads succeed
  while IFS=$'\t' read -r id _ type; do
    [[ -n "$id" ]] || continue
    [[ "$type" == EFI* ]] && continue        # never auto-mount EFI system partitions
    all+=("/dev/$id")
    fst="$(fstype "$id")"
    fs_is_encrypted "$fst" && enc+=("/dev/$id")
    fs_is_mountable "$fst" && mnt+=("/dev/$id")
  done <<< "$rows"

  # prefer a single encrypted volume, else a single mountable volume
  if [[ ${#enc[@]} -eq 1 ]]; then printf '%s' "${enc[0]}"; return 0; fi
  if [[ ${#enc[@]} -gt 1 ]]; then err "$(t det.multi "${enc[*]}")"; err "$(t det.hintcfg)"; return 1; fi
  if [[ ${#mnt[@]} -eq 1 ]]; then printf '%s' "${mnt[0]}"; return 0; fi
  if [[ ${#mnt[@]} -gt 1 ]]; then err "$(t det.multi "${mnt[*]}")"; err "$(t det.hintcfg)"; return 1; fi

  # No recognized filesystem. Do NOT auto-mount an unclassified device — make
  # the user name it explicitly (perform_mount will then ask for confirmation).
  err "$(t det.cantauto "${all[*]:-N/A}")"
  err "$(t det.hintcfg2)"
  return 1
}

# Resolve the device to use: CLI arg > config DEVICE (identity-checked) > auto-detect
# Arg 2 (mode) is used to require a strong identity before an explicit rw mount.
resolve_device() {
  local arg="${1:-}" mode="${2:-ro}"
  if [[ -n "$arg" ]]; then
    # An explicit CLI device must clear the same bar as auto-detect/config —
    # never trust a raw path straight into (rw) mount. Reject whole-disk/internal
    # paths, require an external partition, and canonicalize (strip a raw-device
    # 'r') so the later host_mounted() double-mount check can't be dodged by a
    # /dev/rdiskXsY variant. For rw, additionally require a strong identity so a
    # stale disk number can't silently point a writer at a different drive.
    local dev
    dev="$(canonical_device "$arg")"
    # Must be an external PARTITION (diskXsY), never a whole disk (diskX),
    # internal disk, or raw path variant. Canonicalization above already stripped
    # a leading raw-device 'r' so the later host_mounted() double-mount check
    # can't be dodged by a /dev/rdiskXsY variant.
    [[ "$dev" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || die "$(t cfg.deverr)"
    device_is_external_partition "$dev" || die "$(t det.cantauto "$dev")"
    # Reject EFI system partitions here too — the external-partition check above
    # does NOT filter EFI, so an explicit `rw /dev/diskXs1` would otherwise flow
    # (EFI is FAT) straight into a rw mount and corrupt boot/EFI metadata. Apply
    # the same rejection auto-detect and the wizard use.
    device_is_efi "$dev" && die "$(t det.cantauto "$dev")"
    if [[ "$mode" == "rw" ]]; then
      # For rw, require a strong identity so a stale disk number can't silently
      # point a writer at a different drive.
      strong_device_identity "$dev" >/dev/null 2>&1 || die "$(t dev.weakid "$dev")"
    fi
    printf '%s' "$dev"; return 0
  fi
  if [[ -n "$DEVICE" ]]; then
    # Guard against diskN drift, FAIL CLOSED: a pinned DEVICE is only trusted
    # when we have a saved identity AND can recompute it AND it still matches.
    # A legacy config with DEVICE but no DEVICE_ID, or a diskutil read that
    # fails to recompute, must refuse — never silently operate on whatever disk
    # happens to occupy this path (that risks a rw mount hitting the wrong drive).
    if [[ -z "$DEVICE_ID" ]]; then
      die "$(t dev.noid "$DEVICE")"
    fi
    # Same external-partition guard applied to explicit CLI devices (above): a
    # pinned DEVICE must still be an external partition at use time, so an
    # internal / non-external / EFI partition can never be unmounted and (rw)
    # mounted by bltusb even when its identity matches.
    device_is_external_partition "$DEVICE" || die "$(t det.cantauto "$DEVICE")"
    # device_is_external_partition does NOT filter EFI (EFI is a FAT external
    # partition), so a legacy/hand-edited config whose DEVICE_ID still matches an
    # EFI system partition would otherwise flow into a rw mount and corrupt
    # boot/EFI metadata. Apply the same EFI rejection used on the explicit-CLI and
    # config-set paths.
    device_is_efi "$DEVICE" && die "$(t det.cantauto "$DEVICE")"
    local cur
    cur="$(strong_device_identity "$DEVICE" 2>/dev/null || true)"
    if [[ -z "$cur" ]]; then
      die "$(t dev.recompfail "$DEVICE")"
    fi
    if [[ "$cur" != "$DEVICE_ID" ]]; then
      die "$(t dev.mismatch "$DEVICE")"
    fi
    printf '%s' "$DEVICE"; return 0
  fi
  autodetect_device
}

# ---------------------------------------------------------------------------
# Mount state & core mount
# ---------------------------------------------------------------------------
current_mountpoint() {
  local mp
  mp="$(anylinuxfs status 2>/dev/null | grep -oE '/Volumes/[^ ]+' | head -1 || true)"
  # Defense in depth before it flows into `open`, `anylinuxfs unmount -w`, and cd
  # hints (all of which already quote it / consume it via %s): require a /Volumes
  # path and reject CONTROL characters — the real residual risk from a hostile or
  # garbled volume name is terminal-escape injection, not shell injection. We do
  # NOT restrict to ASCII: Unicode volume labels (e.g. /Volumes/备份) are valid
  # and an ASCII-only whitelist would wrongly report such drives as "not mounted".
  if [[ "$mp" != /Volumes/* || "$mp" == *[[:cntrl:]]* ]]; then mp=""; fi
  printf '%s' "$mp"
}
is_mounted() { [[ -n "$(current_mountpoint)" ]]; }

# Run `anylinuxfs mount`. The passphrase (arg 1) is handed to anylinuxfs via the
# ALFS_PASSPHRASE environment variable — anylinuxfs exposes no stdin/fd channel
# for the secret, so the env var is the only supported mechanism. Keeping it out
# of argv means it never shows in a plain `ps`; note that an env-aware listing
# (`ps -E`, or reading the child's environ) can still observe it for the brief
# lifetime of the mount subprocess. We therefore (a) scope the variable to just
# this one command (an inline `VAR=val cmd` assignment, never an exported/global
# that would leak into every later child), (b) pass it only when a passphrase is
# actually needed, and (c) never echo the value to any log — the info() lines
# print `--preserve-env=ALFS_PASSPHRASE` but never the passphrase itself.
# Remaining args are the mount options + dev.
run_mount() {
  local pass="$1"; shift
  # stdin from /dev/null: the mount must NOT consume our stdin, or it would eat
  # the answer to the follow-up "remember this drive?" prompt.
  if [[ -n "$pass" ]]; then
    ALFS_PASSPHRASE="$pass" sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount "$@" </dev/null
  else
    sudo anylinuxfs mount "$@" </dev/null
  fi
}

# perform_mount <device> <ro|rw> <do_open:true|false>
perform_mount() {
  local dev="$1" mode="$2" do_open="${3:-false}"

  sudo -v 2>/dev/null || true          # prime sudo (mounting needs root anyway)
  local fst; fst="$(fstype "$dev")"

  # Guard #1: never let anylinuxfs touch the raw device while macOS still has the
  # filesystem mounted. exFAT/FAT are host-mounted read-WRITE (two writers →
  # corruption); even NTFS/host-read-only mounts mean macOS may flush dirty
  # metadata (Spotlight, .DS_Store, FAT tables) while anylinuxfs reads the same
  # structures, yielding a torn/inconsistent view. Fail closed for BOTH rw and
  # ro rather than proceeding on top of a live host mount.
  if ! release_host_mount "$dev"; then
    warn "$(t host.busyforce)"
    die "$(t host.busy "$dev")"
  fi

  # Read-only options. For ext, add norecovery so a "read-only" mount can't
  # silently write via journal replay on a dirty volume.
  local opts=(-w false)
  if [[ "$mode" != "rw" ]]; then
    if [[ "$fst" == ext ]]; then opts+=(-o "ro,norecovery"); else opts+=(-o ro); fi
  fi

  step "$(t mnt.mounting "$dev" "$mode")"
  [[ "$mode" == "rw" ]] && warn "$(t mnt.rwwarn)"

  local rc=0
  if fs_is_encrypted "$fst"; then
    # Per-drive password: try this volume's own saved password (or env) first;
    # if it fails — re-encrypted transfer drive, locked/empty Keychain — fall
    # back to prompting and retry once. On success, offer to remember (opt-in).
    local key; key="$(device_key "$dev")"
    local qp; qp="$(get_passphrase_quiet "$key")"
    if [[ -n "$qp" ]]; then
      info "sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount ${opts[*]} ${dev}"
      run_mount "$qp" "${opts[@]}" "$dev" || rc=$?
      [[ $rc -ne 0 ]] && warn "$(t pass.savedfail)"
    else
      rc=1
    fi
    if [[ $rc -ne 0 ]] && ! is_mounted; then
      local pp; pp="$(prompt_passphrase_only)"
      info "sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount ${opts[*]} ${dev}"
      rc=0; run_mount "$pp" "${opts[@]}" "$dev" || rc=$?
      [[ $rc -eq 0 ]] && offer_save "$pp" "$key"
    fi
  elif fs_is_plain "$fst"; then
    info "${C_DIM}$(t mnt.noenc "$fst")${C_RESET}"
    info "sudo anylinuxfs mount ${opts[*]} ${dev}"
    run_mount "" "${opts[@]}" "$dev" || rc=$?
  else
    # Guard #5: unrecognized filesystem — never silently mount or auto-send a
    # stored password; require explicit confirmation.
    warn "$(t mnt.unknownfs "$fst")"
    printf '%s' "${C_CYN}$(t mnt.unknownask)${C_RESET}" >&2
    local uans; read -r uans
    case "${uans:-N}" in [yY]*) : ;; *) die "$(t mnt.cancelled2)" ;; esac
    info "sudo anylinuxfs mount ${opts[*]} ${dev}"
    run_mount "" "${opts[@]}" "$dev" || rc=$?
  fi

  if [[ $rc -eq 0 ]]; then
    local mp; mp="$(current_mountpoint)"
    ok "$(t mnt.success "${mp:+ → $mp}")  ${C_DIM}(${mode})${C_RESET}"
    [[ -n "$mp" ]] && printf '   %s\n' "${C_DIM}$(t mnt.cd "$mp")${C_RESET}"
    if [[ "$do_open" == "true" && -n "$mp" ]]; then open "$mp"; fi
    return 0
  else
    err "$(t mnt.fail)"
    err "$(t mnt.failhint)"
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Interactive wizard (default action when run with no arguments)
# ---------------------------------------------------------------------------
cmd_auto() {
  ensure_installed

  if is_mounted; then
    local mp; mp="$(current_mountpoint)"
    info "$(t wiz.mountedopen "$mp")"
    open "$mp"; ok "$(t open.done)"
    return 0
  fi

  step "$(t wiz.detecting)"
  sudo -v 2>/dev/null || true   # prime sudo so filesystem detection can read signatures
  local ids=() sizes=() types=() fsts=() rec=0 rec_enc=0 rec_any=0 n=0 id size type fst
  while IFS=$'\t' read -r id size type; do
    [[ -n "$id" ]] || continue
    # Never make the EFI system partition selectable: like autodetect_device,
    # exclude it from the list entirely so a user can't accidentally pick a FAT
    # EFI partition and rw-mount it (that partition must never be user-mounted).
    [[ "$type" == EFI* ]] && continue
    fst="$(fstype "$id")"
    ids+=("$id"); sizes+=("$size"); types+=("$type"); fsts+=("$fst")
    fs_is_encrypted "$fst" && [[ $rec_enc -eq 0 ]] && rec_enc=$((n+1))
    if fs_is_mountable "$fst" && [[ $rec_any -eq 0 ]]; then rec_any=$((n+1)); fi
    n=$((n+1))
  done <<< "$(list_partition_rows | sanitize_display)"   # sanitize: labels reach the terminal at the printf below

  [[ $n -gt 0 ]] || { err "$(t wiz.none)"; return 1; }
  if [[ $rec_enc -gt 0 ]]; then rec=$rec_enc; elif [[ $rec_any -gt 0 ]]; then rec=$rec_any; else rec=1; fi

  local choice="$rec"
  if [[ $n -eq 1 ]]; then
    choice=1
    info "/dev/${ids[0]}  ${C_DIM}${sizes[0]}  ${fsts[0]}${C_RESET}"
  else
    echo; printf '%s\n' "$(t wiz.pick)"
    local i mark
    for ((i=0; i<n; i++)); do
      if fs_is_mountable "${fsts[$i]}"; then mark="${C_GRN}${fsts[$i]}${C_RESET}"; else mark="${C_DIM}${fsts[$i]}${C_RESET}"; fi
      fs_is_encrypted "${fsts[$i]}" && mark="$mark ${C_YEL}🔒${C_RESET}"
      [[ $((i+1)) -eq $rec ]] && mark="$mark ${C_DIM}($(t wiz.recommended))${C_RESET}"
      printf '  %s) %-12s %-9s %-16s %s\n' "$((i+1))" "/dev/${ids[$i]}" "${sizes[$i]}" "${types[$i]}" "$mark"
    done
    printf '%s' "$(t wiz.devask "$rec")"
    local ans; read -r ans
    [[ -n "$ans" ]] && choice="$ans"
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > n )); then die "$(t wiz.invalid)"; fi
  fi

  local sel="/dev/${ids[$((choice-1))]}"

  # Mode: default read-only
  echo; printf '%s\n' "$(t wiz.modehdr)"
  printf '  1) %s\n' "$(t wiz.modero)"
  printf '  2) %s\n' "$(t wiz.moderw)"
  printf '%s' "$(t wiz.modeask)"
  local mans mode="ro"; read -r mans
  [[ "$mans" == "2" ]] && mode="rw"

  # Route through resolve_device so the wizard's rw path gets the same
  # strong-device-identity gate as cmd_mount: a disk number that has drifted
  # after a replug must never silently point a read-write mount at a different
  # physical drive.
  local dev; dev="$(resolve_device "$sel" "$mode")" || return 1

  echo
  perform_mount "$dev" "$mode" "false" || return 1

  # Offer to open in Finder
  local mp; mp="$(current_mountpoint)"
  if [[ -n "$mp" ]]; then
    printf '%s' "$(t wiz.openask)"
    local oans; read -r oans
    case "${oans:-Y}" in [nN]*) : ;; *) open "$mp"; ok "$(t open.done)" ;; esac
  fi
  [[ "$mode" == "ro" ]] && info "${C_DIM}$(t wiz.rwhint)${C_RESET}"
}

# ---------------------------------------------------------------------------
# Commands: mount / rw / umount / status / detect / open
# ---------------------------------------------------------------------------
cmd_mount() {
  local mode="$DEFAULT_MODE" dev_arg="" do_open="false" a
  for a in "$@"; do
    case "$a" in
      ro|readonly) mode="ro" ;;
      rw|readwrite) mode="rw" ;;
      --open) do_open="true" ;;
      /dev/*) dev_arg="$a" ;;
      disk*) dev_arg="/dev/$a" ;;
      *) warn "ignoring unknown arg: $a" ;;
    esac
  done

  ensure_installed

  if is_mounted; then
    warn "$(t mnt.already "$(current_mountpoint)")"
    warn "$(t mnt.switchhint)"
    return 0
  fi

  local dev; dev="$(resolve_device "$dev_arg" "$mode")" || exit 1
  perform_mount "$dev" "$mode" "$do_open" || exit 1
}

cmd_rw() { cmd_mount rw "$@"; }

cmd_umount() {
  if ! is_mounted; then
    info "$(t umt.none)"
    return 0
  fi
  local mp; mp="$(current_mountpoint)"
  step "$(t umt.unmounting "$mp")"
  sync 2>/dev/null || true            # flush host dirty pages to the VM first
  # -w waits for the microVM to fully exit (finish flushing to the USB) before returning.
  # Pass the captured mountpoint so ONLY this volume is torn down: a bare
  # `anylinuxfs unmount` unmounts ALL anylinuxfs mounts and could interrupt a
  # second, actively-flushing rw mount (data-loss path).
  if sudo anylinuxfs unmount -w "$mp"; then
    ok "$(t umt.done)"
    ok "$(t umt.saferemove)"
  else
    err "$(t umt.fail)"
    exit 1
  fi
}

cmd_status() {
  ensure_installed
  step "$(t st.header)"
  local out; out="$(anylinuxfs status 2>/dev/null | sanitize_display || true)"
  if [[ -n "$out" ]]; then
    printf '%s\n' "$out"
    local mp; mp="$(current_mountpoint)"
    [[ -n "$mp" ]] && ok "$(t st.mounted "$mp")"
  else
    info "$(t st.none)"
  fi
  echo
  step "$(t st.extdisks)"
  local ext; ext="$(diskutil list external physical 2>/dev/null | sanitize_display || true)"
  if [[ -n "$ext" ]]; then printf '%s\n' "$ext"; else info "$(t st.noext)"; fi
}

cmd_detect() {
  step "$(t det.header)"
  sudo -v 2>/dev/null || true
  local parts p fst any="false"
  parts="$(list_external_partitions)"
  [[ -n "$parts" ]] || { info "$(t det.nopart)"; return 0; }
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    fst="$(fstype "$p")"
    if fs_is_mountable "$fst"; then
      any="true"
      if fs_is_encrypted "$fst"; then
        ok "${C_GRN}/dev/$p${C_RESET}  ${C_BOLD}$fst${C_RESET}  ${C_YEL}🔒 $(t fs.encrypted)${C_RESET}"
      else
        ok "${C_GRN}/dev/$p${C_RESET}  ${C_BOLD}$fst${C_RESET}"
      fi
    else
      printf '   %s\n' "${C_DIM}/dev/$p  $fst${C_RESET}"
    fi
  done <<< "$parts"
  [[ "$any" == "true" ]] || warn "$(t det.noconfirm)"
}

cmd_open() {
  if is_mounted; then
    open "$(current_mountpoint)"; ok "$(t open.done)"
  else
    cmd_mount --open "$@"
  fi
}

# ---------------------------------------------------------------------------
# Command: config
# ---------------------------------------------------------------------------
cmd_config() {
  local sub="${1:-show}"; shift || true
  case "$sub" in
    show|"")
      step "$(t cfg.header)"
      printf '  %-9s: %s\n' "$(t cfg.file)"   "$CONFIG_FILE"
      printf '  %-9s: %s\n' "$(t cfg.device)" "${DEVICE:-$(t cfg.auto)}"
      printf '  %-9s: %s\n' "$(t cfg.mode)"   "$DEFAULT_MODE"
      printf '  %-9s: %s\n' "$(t cfg.lang)"   "$(lang_name "$BLTUSB_LANG_CODE")"
      printf '  %-9s: %s\n' "$(t cfg.password)" "${C_DIM}$(t cfg.pass.perdrive)${C_RESET}"
      local austate; if [[ "$AUTOUNLOCK" == "on" ]]; then austate="$(t au.status.on)"; else austate="$(t au.status.off)"; fi
      printf '  %-9s: %s\n' "$(t au.status.header)" "$austate"
      local auvia; if [[ "$(autounlock_via)" == "brew" ]]; then auvia="$(t au.via.brew)"; else auvia="$(t au.via.self)"; fi
      printf '  %-9s: %s\n' "$(t au.status.via)" "$auvia"
      ;;
    set-device|device)
      local d="${1:-}"
      [[ -n "$d" ]] || { printf '%s' "$(t cfg.devprompt)"; read -r d; }
      if [[ -n "$d" && ! "$d" =~ ^/dev/disk[0-9]+s[0-9]+$ ]]; then die "$(t cfg.deverr)"; fi
      if [[ -n "$d" ]]; then
        # Never pin a non-external partition (internal disk / EFI / stale path):
        # match the guard applied on the explicit-CLI and pinned mount paths so a
        # dangerous device can't be persisted and later (rw) mounted.
        device_is_external_partition "$d" || die "$(t det.cantauto "$d")"
        # Never pin an EFI system partition: external_partition does not filter
        # EFI, so without this a pinned EFI (FAT) could later be (rw) mounted and
        # corrupt boot/EFI metadata. Same rejection as auto-detect / the wizard.
        device_is_efi "$d" && die "$(t det.cantauto "$d")"
        # Require a STRONG identity (UUID or boot-sector fingerprint) before we
        # pin a device — never persist an empty or label+size-only identity, or
        # the drift guard in resolve_device would be silently disabled.
        DEVICE_ID="$(strong_device_identity "$d" 2>/dev/null || true)"
        [[ -n "$DEVICE_ID" ]] || die "$(t dev.weakid "$d")"
      else
        DEVICE_ID=""   # empty DEVICE = auto-detect each time; no identity to pin
      fi
      DEVICE="$d"
      save_config
      ;;
    set-mode|mode)
      local m="${1:-}"
      case "$m" in ro|rw) DEFAULT_MODE="$m"; save_config ;; *) die "$(t cfg.modeerr)" ;; esac
      ;;
    init)
      step "$(t cfg.init.header)"
      printf '%s' "$(t cfg.init.dev)"; read -r DEVICE
      if [[ -n "$DEVICE" ]]; then
        if [[ ! "$DEVICE" =~ ^/dev/disk[0-9]+s[0-9]+$ ]]; then die "$(t cfg.deverr)"; fi
        # Never pin a non-external partition (internal / EFI / stale path):
        # match the mount-path guard so a dangerous device can't be persisted.
        device_is_external_partition "$DEVICE" || die "$(t det.cantauto "$DEVICE")"
        # Never pin an EFI system partition (external_partition does not filter
        # EFI, and EFI is FAT so it would otherwise be rw-mountable): reject it
        # the same way auto-detect and the wizard do before persisting.
        device_is_efi "$DEVICE" && die "$(t det.cantauto "$DEVICE")"
        # Require a strong identity to pin the device; abort rather than persist
        # an empty/weak one that would disable the diskN-drift guard.
        DEVICE_ID="$(strong_device_identity "$DEVICE" 2>/dev/null || true)"
        [[ -n "$DEVICE_ID" ]] || die "$(t dev.weakid "$DEVICE")"
      else
        DEVICE_ID=""
      fi
      printf '%s' "$(t cfg.init.mode)"; local m; read -r m
      if [[ "$m" == "rw" ]]; then DEFAULT_MODE="rw"; else DEFAULT_MODE="ro"; fi
      save_config
      ;;
    *) die "$(t cfg.unknownsub "$sub")" ;;
  esac
}

# ---------------------------------------------------------------------------
# Command: forget — remove a saved per-drive password (opt-in cleanup)
# ---------------------------------------------------------------------------
cmd_forget() {
  local arg="${1:-}"
  # Prime sudo before device_key: on a cold terminal an MBR/BitLocker-To-Go drive
  # has no Partition UUID, so device_key falls back to a `sudo -n dd` boot-sector
  # read. Without a warm sudo timestamp that read fails, device_key now returns
  # empty, and forget would report "no saved password" while leaving the real
  # per-device Keychain entry behind. Priming makes the fingerprint reproducible.
  sudo -v 2>/dev/null || true
  case "$arg" in
    --all)
      printf '%s' "${C_YEL}$(t forget.allask)${C_RESET}" >&2
      local ans; read -r ans
      case "${ans:-N}" in
        [yY]*)
          while security delete-generic-password -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1; do :; done
          ok "$(t forget.alldone)"
          ;;
        *) info "$(t mnt.cancelled2)" ;;
      esac
      ;;
    /dev/*|disk*)
      local dev="$arg"; [[ "$arg" == disk* ]] && dev="/dev/$arg"
      # Canonicalize (strip a raw-device 'r', trailing slash) and enforce the SAME
      # /dev/diskNsM partition regex resolve_device uses, BEFORE any raw read. This
      # stops a crafted path like /dev/../../etc/hostconfig from reaching the
      # `sudo dd if=/dev/r${dev#/dev/}` boot-sector read in device_key (root would
      # otherwise read 512 bytes of an attacker-named file into a discarded hash).
      dev="$(canonical_device "$dev")"
      [[ "$dev" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || die "$(t cfg.deverr)"
      local key; key="$(device_key "$dev")"
      [[ -n "$key" ]] || die "$(t forget.none "$dev")"
      if [[ -n "$(keychain_get "$key")" ]]; then keychain_del "$key"; ok "$(t forget.done "$dev")"; else info "$(t forget.none "$dev")"; fi
      ;;
    ""|*) die "$(t forget.usage)" ;;
  esac
}

# ---------------------------------------------------------------------------
# Auto-unlock (Phase-0 personal-dev convenience): a per-user LaunchAgent runs
# `diskutil activity` and, on each external partition insert, auto-mounts it
# read-only — trying the Keychain/env passphrase first, else a native GUI
# dialog. This is ADDITIVE and OPT-IN. It reuses every existing guard
# (device_is_external_partition / device_is_efi / fs_is_mountable / the
# host-mount double-writer check) and the per-device Keychain discipline. It
# NEVER auto-mounts rw, NEVER touches internal/EFI/whole disks, and NEVER puts
# any secret into argv / a logged command / a temp file.
#
# Test hooks (no real GUI / drive / sudo needed, so CI can exercise the flow):
#   BLTUSB_AUTOUNLOCK_DRYRUN=1  — scan/mount print the intended action and
#                                 return without invoking sudo/anylinuxfs.
#   BLTUSB_OSASCRIPT_STUB=<path> — every GUI call runs "<path> <args...>"
#                                 instead of the real `osascript`, so a stub
#                                 can echo a canned passphrase / button.
# ---------------------------------------------------------------------------

# Resolve THIS running script's absolute path, for the LaunchAgent plist. Prefer
# a symlink-resolved path so a plist can't be pinned to a mutable symlink.
autounlock_self_path() {
  local src="${BASH_SOURCE[0]}" dir
  if command -v realpath >/dev/null 2>&1; then
    realpath "$src" 2>/dev/null && return 0
  fi
  # Fallback: resolve via cd/pwd -P (no realpath on older systems).
  dir="$(cd "$(dirname "$src")" >/dev/null 2>&1 && pwd -P)" || return 1
  printf '%s/%s' "$dir" "$(basename "$src")"
}

# Canonicalize a path (resolve symlinks) so two paths to the same file compare
# equal. realpath(1) exists on modern macOS; fall back to cd/pwd -P.
_realpath() {
  if command -v realpath >/dev/null 2>&1; then realpath "$1" 2>/dev/null; return; fi
  local d; d="$(cd "$(dirname "$1")" 2>/dev/null && pwd -P)" || return 1
  printf '%s/%s' "$d" "$(basename "$1")"
}

# Decide the install mechanism: 'brew' ONLY when the RUNNING binary IS the
# Homebrew-managed formula binary (canonical-identity match against
# `brew --prefix bltusb`/bin/bltusb) — so a manual/dev install, even one that
# happens to live under the brew prefix, correctly uses 'self'. Fail-safe to
# 'self' on any uncertainty. No env override: the mechanism is derived, not
# forced, so nothing external can flip it.
autounlock_via() {
  command -v brew >/dev/null 2>&1 || { printf 'self'; return 0; }
  local self fprefix fbin
  self="$(autounlock_self_path)" || { printf 'self'; return 0; }
  self="$(_realpath "$self" 2>/dev/null || printf '%s' "$self")"
  fprefix="$(brew --prefix bltusb 2>/dev/null)" || { printf 'self'; return 0; }
  [[ -n "$fprefix" ]] || { printf 'self'; return 0; }
  fbin="$(_realpath "$fprefix/bin/bltusb" 2>/dev/null || true)"
  [[ -n "$fbin" && "$self" == "$fbin" ]] && { printf 'brew'; return 0; }
  printf 'self'
}

# Deactivate a specific mechanism and VERIFY it — used to ENFORCE that only ONE
# auto-unlock daemon is ever active, even across a self<->brew transition.
# Deactivate the self-managed agent and VERIFY it is gone. Returns 0 only when
# the agent is confirmed inactive (not loaded AND no plist) so callers can
# enforce the single-daemon invariant rather than hope.
_autounlock_stop_self() {
  launchctl bootout "$(_au_domain)/${AUTOUNLOCK_LABEL}" >/dev/null 2>&1 || true
  rm -f "$AUTOUNLOCK_PLIST" 2>/dev/null || true
  ! launchctl print "$(_au_domain)/${AUTOUNLOCK_LABEL}" >/dev/null 2>&1 && [[ ! -f "$AUTOUNLOCK_PLIST" ]]
}
# Deactivate the Homebrew service and VERIFY it is not `started`. Returns 0 when
# there's no brew (nothing to stop) or the service is confirmed stopped.
_autounlock_stop_brew() {
  command -v brew >/dev/null 2>&1 || return 0
  brew services stop bltusb >/dev/null 2>&1 || true
  # Separate query success from state inspection: a FAILED `brew services list`
  # must NOT read as "stopped". Under pipefail, `! list | awk | grep` would turn a
  # failed query into a false "verified stopped". Capture first, fail closed if
  # the query itself fails (return 1), then inspect the state.
  local services state
  services="$(brew services list 2>/dev/null)" || return 1
  state="$(printf '%s\n' "$services" | awk '$1=="bltusb"{print $2; exit}')"
  [[ "$state" != "started" ]]
}

# Run osascript, or the test stub when BLTUSB_OSASCRIPT_STUB is set. The stub
# receives the SAME argv as osascript would (so a test can inspect / respond to
# the AppleScript program text) and its stdout is returned verbatim.
_osascript() {
  if [[ -n "${BLTUSB_OSASCRIPT_STUB:-}" ]]; then
    "$BLTUSB_OSASCRIPT_STUB" "$@"
  else
    osascript "$@"
  fi
}

# Escape a string for safe interpolation into an AppleScript double-quoted
# literal: backslash FIRST, then double-quote. sanitize_display strips control
# and bidi codepoints but NOT backslashes or quotes, so without this a crafted
# volume label such as  x\" & (do shell script "...")  could break out of the
# AppleScript string and inject code on the auto-unlock (hostile-media) path.
# Additionally collapse C0 control bytes (NUL..US, incl. LF/CR/TAB) and DEL to a
# space: sanitize_display deliberately keeps \x09/\x0A, but a raw newline/CR in a
# label would terminate the AppleScript `-e` string literal → osascript compile
# error → the auto-unlock GUI prompt silently wedges (fail-closed DoS on crafted
# media). Fold them here, the last gate before the osascript program text.
_as_escape() {
  local s="$1"
  s="${s//\\/\\\\}"; s="${s//\"/\\\"}"
  # Fold every C0 control (0x01-0x1F — covers LF 0x0A, CR 0x0D, TAB 0x09) and DEL
  # (0x7F) to a space so a raw newline/CR in the label can never terminate the
  # AppleScript `-e` string literal. A bash variable cannot hold a NUL (0x00), so
  # the range starts at 0x01. printf|tr is byte-safe and never fatal.
  s="$(printf '%s' "$s" | LC_ALL=C tr '\001-\037\177' ' ')"
  printf '%s' "$s"
}

# Native GUI passphrase dialog (hidden answer). The secret is printed on stdout
# and captured by the caller into a shell variable — it is NEVER placed in the
# AppleScript program text or in argv. The volume label (arg 1) is display-only
# and MUST already be sanitized by the caller. Returns non-zero on cancel/empty.
gui_prompt_passphrase() {   # <label-for-display>
  local label="$1" prompt title pw
  prompt="$(t au.dialog.prompt "$label")"
  title="$(t au.dialog.title)"
  # `giving up after 120` auto-dismisses so a forgotten dialog can't wedge the
  # daemon. The prompt/title are our own translated literals (label already
  # sanitized), so they cannot inject AppleScript.
  pw="$(_osascript -e "display dialog \"$(_as_escape "$prompt")\" default answer \"\" with title \"$(_as_escape "$title")\" with hidden answer giving up after 120" 2>/dev/null | sed -n 's/.*text returned:\(.*\), gave up:.*/\1/p; s/.*text returned:\(.*\)$/\1/p' | head -1)"
  [[ -n "$pw" ]] || return 1
  printf '%s' "$pw"
}

# After a successful auto-mount, offer (GUI) to remember this drive's password.
# Recovery keys are never saved (reuse is_recovery_key). Needs a stable key.
gui_offer_save() {   # <password> <device_key> <label-for-display>
  [[ -n "$2" ]] || return 0
  is_recovery_key "$1" && return 0
  local prompt title yes no ans
  prompt="$(t au.remember.prompt "$3")"; title="$(t au.remember.title)"
  yes="$(t au.remember.yes)"; no="$(t au.remember.no)"
  ans="$(_osascript -e "display dialog \"$(_as_escape "$prompt")\" with title \"$(_as_escape "$title")\" buttons {\"$(_as_escape "$no")\", \"$(_as_escape "$yes")\"} default button 2 giving up after 60" 2>/dev/null || true)"
  case "$ans" in *"button returned:$yes"*) keychain_set "$1" "$2" ;; *) : ;; esac
}

# Native notification banner (no secret ever passes through here — callers pass
# only a display label, already sanitized).
notify() {   # <message>
  local msg="$1" title
  title="$(t au.dialog.title)"
  _osascript -e "display notification \"$(_as_escape "$msg")\" with title \"$(_as_escape "$title")\"" >/dev/null 2>&1 || true
}

# Generate a throwaway SUDO_ASKPASS helper at a private 0700 path. It contains
# NO secret: it merely pops a native osascript GUI dialog for the macOS ADMIN
# password (distinct from the BitLocker passphrase) and prints it to stdout for
# sudo. Echoes the helper path; caller removes it after use.
make_askpass_helper() {
  local dir helper prompt title
  dir="$(mktemp -d "${TMPDIR:-/tmp}/bltusb-askpass.XXXXXX")" || return 1
  chmod 700 "$dir"
  helper="$dir/askpass"
  prompt="$(t au.admin.prompt)"; title="$(t au.dialog.title)"
  # The helper runs osascript itself; the prompt/title are our own literals. The
  # admin password flows osascript -> stdout -> sudo, never into a file or argv.
  {
    printf '#!/bin/sh\n'
    printf 'exec /usr/bin/osascript -e %s\n' \
      "'display dialog \"${prompt//\"/\\\"}\" default answer \"\" with title \"${title//\"/\\\"}\" with hidden answer with icon caution' -e 'text returned of result'"
  } > "$helper"
  chmod 700 "$helper"
  printf '%s' "$helper"
}

# Warm the sudo timestamp via a GUI admin dialog so a later `sudo -n` (used by
# fstype()/run_mount_gui) succeeds without a terminal. Fast path first: if the
# timestamp is already valid, return silently (no prompt). Otherwise pop the same
# no-secret askpass helper and validate the timestamp with `sudo -A true`. The
# admin password never touches a file or argv. Returns non-zero if warming failed
# (caller treats that as "skip silently" — the mount path then fails closed).
warm_sudo_gui() {
  sudo -n true 2>/dev/null && return 0
  local h; h="$(make_askpass_helper)" || return 1
  SUDO_ASKPASS="$h" sudo -A true </dev/null >/dev/null 2>&1
  local rc=$?
  rm -rf "$(dirname "$h")" 2>/dev/null || true
  return $rc
}

# Run `anylinuxfs mount` for the auto-unlock path WITHOUT a controlling
# terminal. Fast path: `sudo -n` (cached timestamp, silent). On failure, use
# `sudo -A` with a GUI askpass helper for the ADMIN password. The BitLocker
# passphrase (arg 1) still travels only via the ALFS_PASSPHRASE-scoped
# --preserve-env mechanism, never in argv or AppleScript text. Args after the
# passphrase are the mount options + device.
run_mount_gui() {
  local pass="$1"; shift
  local rc=0
  if [[ -n "$pass" ]]; then
    if ALFS_PASSPHRASE="$pass" sudo -n --preserve-env=ALFS_PASSPHRASE anylinuxfs mount "$@" </dev/null >/dev/null 2>&1; then
      return 0
    fi
    local helper; helper="$(make_askpass_helper)" || return 1
    ALFS_PASSPHRASE="$pass" SUDO_ASKPASS="$helper" sudo -A --preserve-env=ALFS_PASSPHRASE anylinuxfs mount "$@" </dev/null >/dev/null 2>&1 || rc=$?
    rm -rf "$(dirname "$helper")" 2>/dev/null || true
    return "$rc"
  else
    if sudo -n anylinuxfs mount "$@" </dev/null >/dev/null 2>&1; then
      return 0
    fi
    local helper; helper="$(make_askpass_helper)" || return 1
    SUDO_ASKPASS="$helper" sudo -A anylinuxfs mount "$@" </dev/null >/dev/null 2>&1 || rc=$?
    rm -rf "$(dirname "$helper")" 2>/dev/null || true
    return "$rc"
  fi
}

# Re-verify a device is still the SAME safe target after the passphrase dialog
# (TOCTOU guard): identical strong identity AND still an external partition AND
# not EFI AND not host-mounted. Returns non-zero on any mismatch so the caller
# aborts without mounting. A blank captured identity is treated as a mismatch
# (we require a stable identity to re-anchor to).
_autounlock_reverify() {   # <device> <captured-strong-identity>
  local dev="$1" id0="$2" id1
  [[ -n "$id0" ]] || return 1
  id1="$(strong_device_identity "$dev" 2>/dev/null || true)"
  [[ "$id1" == "$id0" ]] || return 1
  device_is_external_partition "$dev" || return 1
  device_is_efi "$dev" && return 1
  host_mounted "$dev" && return 1
  return 0
}

# Auto-mount ONE freshly-inserted external partition, read-only, no terminal.
# Fails CLOSED and SILENTLY on anything ambiguous (unknown fs, already mounted,
# EFI/whole-disk/internal) — no "mount anyway?" dialog on the auto path.
autounlock_mount() {   # <device>
  local dev; dev="$(canonical_device "$1")"
  # Same guards the interactive paths use.
  [[ "$dev" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || return 0
  device_is_external_partition "$dev" || return 0
  device_is_efi "$dev" && return 0
  # Never double-mount: if any anylinuxfs mount is already live, or macOS still
  # holds this device, leave it alone (the interactive umount owns teardown).
  is_mounted && return 0
  host_mounted "$dev" && return 0

  local fst; fst="$(fstype "$dev")"
  fs_is_mountable "$fst" || return 0     # unknown fs → silent no-op (fail closed)

  # A display label for dialogs/notifications, sanitized (crafted volume label
  # must not inject into osascript).
  local label; label="$(diskutil info "$dev" 2>/dev/null | awk -F': +' '/Volume Name/{print $2; exit}' | sanitize_display || true)"
  [[ -n "$label" ]] || label="$dev"

  local opts=(-w false)
  if [[ "$fst" == ext ]]; then opts+=(-o "ro,norecovery"); else opts+=(-o ro); fi

  if [[ "${BLTUSB_AUTOUNLOCK_DRYRUN:-}" == "1" ]]; then
    printf 'autounlock: would mount %s ro (fs=%s)\n' "$dev" "$fst"
    return 0
  fi

  # Capture the device's strong identity NOW, before any (≤120s) dialog. The
  # passphrase dialog is a long window in which the physical device behind
  # /dev/diskXsY could be swapped; before we hand this path to the root parser we
  # re-verify the SAME identity and re-run the cheap guards. On any mismatch we
  # abort and do NOT mount (fail closed) — a swapped hostile partition must never
  # reach the mount with credentials collected for the original drive.
  local id0; id0="$(strong_device_identity "$dev" 2>/dev/null || true)"
  local rc=0 key qp pp
  if fs_is_encrypted "$fst"; then
    key="$(device_key "$dev" 2>/dev/null || true)"
    qp="$(get_passphrase_quiet "$key" 2>/dev/null || true)"
    if [[ -n "$qp" ]]; then
      # Even with no dialog, re-anchor to a stable identity before handing the
      # device to the root parser (fail closed on blank/changed identity).
      if ! _autounlock_reverify "$dev" "$id0"; then
        notify "$(t au.notify.failed "$label")"; return 1
      fi
      run_mount_gui "$qp" "${opts[@]}" "$dev" || rc=$?
    else
      rc=1
    fi
    if [[ $rc -ne 0 ]] && ! is_mounted; then
      pp="$(gui_prompt_passphrase "$label")" || { notify "$(t au.notify.failed "$label")"; return 1; }
      # Re-verify device identity across the dialog (TOCTOU): same strong
      # identity, still an external partition, not EFI, not host-mounted.
      if ! _autounlock_reverify "$dev" "$id0"; then
        notify "$(t au.notify.failed "$label")"; return 1
      fi
      rc=0; run_mount_gui "$pp" "${opts[@]}" "$dev" || rc=$?
      [[ $rc -eq 0 ]] && gui_offer_save "$pp" "$key" "$label"
    fi
  else
    # Plain (unencrypted) mountable target — no dialog, but still re-anchor to a
    # stable identity before the root parser touches it (fail closed).
    if ! _autounlock_reverify "$dev" "$id0"; then
      notify "$(t au.notify.failed "$label")"; return 1
    fi
    run_mount_gui "" "${opts[@]}" "$dev" || rc=$?
  fi

  if [[ $rc -eq 0 ]]; then
    local mp; mp="$(current_mountpoint)"
    notify "$(t au.notify.mounted "${mp:-$label}")"
    return 0
  else
    notify "$(t au.notify.failed "$label")"
    return 1
  fi
}

# Scan all external partitions and auto-mount the first mountable, non-EFI,
# non-mounted one. Internal command, hidden from help. Exits 0 even when there
# is nothing to do (so the daemon keeps running).
__autounlock_scan() {
  is_mounted && return 0     # something is already mounted — nothing to do
  local rows id type fst
  rows="$(list_partition_rows 2>/dev/null || true)"
  [[ -n "$rows" ]] || return 0
  sudo -n -v 2>/dev/null || true   # opportunistically warm sudo (silent)
  while IFS=$'\t' read -r id _ type; do
    [[ -n "$id" ]] || continue
    [[ "$id" =~ ^disk[0-9]+s[0-9]+$ ]] || continue
    [[ "$type" == EFI* ]] && continue
    host_mounted "/dev/$id" && continue     # macOS already mounts it → skip
    # A candidate macOS could NOT mount is the real auto-unlock target (e.g. a
    # locked BitLocker volume). But `diskutil activity` can fire DiskAppeared
    # BEFORE macOS finishes auto-mounting a plain FAT/exFAT/NTFS volume, so a
    # normal USB can briefly look unmounted here. Give macOS a moment and re-check
    # host_mounted before treating it as a genuine candidate — otherwise a plain
    # USB would trigger a needless admin prompt. Then warm sudo via the GUI askpass
    # (fstype() below needs `sudo -n dd`; on a cold timestamp it fails → `unknown`
    # → skipped, so "insert → prompt → mount" never works cold). Both the settle
    # and the prompt are skipped on the dryrun / osascript-stub test paths.
    if [[ -z "${BLTUSB_AUTOUNLOCK_DRYRUN:-}" && -z "${BLTUSB_OSASCRIPT_STUB:-}" ]]; then
      sleep 2
      host_mounted "/dev/$id" && continue    # macOS finished mounting it → not a target
      warm_sudo_gui || true    # best-effort; on failure fstype just fails closed
    fi
    fst="$(fstype "/dev/$id" 2>/dev/null || echo unknown)"
    fs_is_mountable "$fst" || continue      # skip unknown fs silently
    # Per-device flock so overlapping DiskAppeared events don't double-mount.
    autounlock_locked "/dev/$id"
    return 0
  done <<< "$rows"
  return 0
}

# Serialize per-device auto-mounts with a flock, so two DiskAppeared events for
# the same disk can't race into a double mount.
autounlock_locked() {   # <device>
  local dev="$1" keyhash lockdir lock
  keyhash="$(printf '%s' "$dev" | shasum -a 256 2>/dev/null | cut -c1-16 || true)"
  [[ -n "$keyhash" ]] || keyhash="${dev//\//_}"
  lockdir="${TMPDIR:-/tmp}/bltusb-autounlock.$(id -u)"
  mkdir -p "$lockdir" 2>/dev/null || true
  chmod 700 "$lockdir" 2>/dev/null || true
  lock="$lockdir/$keyhash.lock"
  if command -v flock >/dev/null 2>&1; then
    (
      flock -n 9 || exit 0
      autounlock_mount "$dev"
    ) 9>"$lock"
  else
    # macOS ships no flock(1); use mkdir as an atomic lock instead.
    local mdlock="$lockdir/$keyhash.mlock"
    if mkdir "$mdlock" 2>/dev/null; then
      autounlock_mount "$dev"
      rmdir "$mdlock" 2>/dev/null || true
    fi
  fi
}

# The resident daemon: stream `diskutil activity` and, on each external-disk
# DiskAppeared event, run a scan. `diskutil activity` blocks until killed; the
# LaunchAgent (KeepAlive) restarts it if it ever exits. Internal, hidden.
__autounlock_daemon() {
  # A brief scan at startup catches a drive already inserted when we loaded.
  __autounlock_scan || true
  # Stream disk-arbitration events. Each ***DiskAppeared line names the disk;
  # we simply re-scan (the scan re-derives the current external partitions and
  # applies every guard), so we don't have to parse the exact identifier.
  diskutil activity 2>/dev/null | while IFS= read -r line; do
    case "$line" in
      *DiskAppeared*) __autounlock_scan || true ;;
    esac
  done
}

# launchctl domain target for the current GUI session.
_au_domain() { printf 'gui/%s' "$(id -u)"; }

# XML-escape a string for safe interpolation into a plist <string>...</string>.
# `&` MUST be escaped first (it introduces every other entity), then the angle
# brackets and the double-quote. Without this a bltusb path containing an `&`,
# `<`, `>` or `"` would produce a malformed plist that launchd rejects.
_xml_escape() {
  local s="$1"
  s="${s//&/&amp;}"; s="${s//</&lt;}"; s="${s//>/&gt;}"; s="${s//\"/&quot;}"
  printf '%s' "$s"
}

autounlock_write_plist() {   # <abs-bltusb-path>
  local bin; bin="$(_xml_escape "$1")"
  local label; label="$(_xml_escape "$AUTOUNLOCK_LABEL")"
  mkdir -p "$(dirname "$AUTOUNLOCK_PLIST")"
  cat > "$AUTOUNLOCK_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${label}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${bin}</string>
    <string>__autounlock-daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
  <key>LimitLoadToSessionType</key>
  <string>Aqua</string>
  <key>StandardOutPath</key>
  <string>/dev/null</string>
  <key>StandardErrorPath</key>
  <string>/dev/null</string>
</dict>
</plist>
EOF
}

cmd_autounlock() {
  local sub="${1:-}"; shift || true
  local a
  for a in "$@"; do
    warn "ignoring unknown arg: $a"
  done

  case "$sub" in
    install)
      ensure_installed
      # Supply-chain awareness: surface a backend that has drifted from the
      # version this release was security-reviewed against (we cannot pin the
      # backend's internal image digest — see docs/AUTO-UNLOCK-RISK.md).
      local av; av="$(anylinuxfs --version 2>/dev/null | awk '{print $2}')"
      [[ -n "$av" && "$av" != "$ANYLINUXFS_PINNED_VERSION" ]] \
        && warn "$(t au.anylinuxfs.ver "$av" "$ANYLINUXFS_PINNED_VERSION")"
      local via; via="$(autounlock_via)"
      if [[ "$via" == "brew" ]]; then
        # Homebrew-managed: delegate the daemon to `brew services` (a per-user
        # agent — NEVER `sudo brew services`, which would be a root LaunchDaemon).
        # First deactivate any self-managed agent so we never run two daemons —
        # and ENFORCE it: refuse to start if it can't be confirmed stopped.
        _autounlock_stop_self || die "$(t au.dedup.failed)"
        # Honesty gate mirrors the self path: report success only if the service
        # actually STARTED — require both a clean `brew services start` exit AND a
        # `brew services list` line showing bltusb `started` (not error/none).
        if ! brew services start bltusb >/dev/null 2>&1 \
           || ! brew services list 2>/dev/null | awk '$1=="bltusb"{print $2}' | grep -q '^started$'; then
          die "$(t au.brew.failed)"
        fi
        AUTOUNLOCK_VIA="brew"
        AUTOUNLOCK="on"; save_config
        ok "$(t au.installed)"
        info "$(t au.brew.installed)"
        info "${C_DIM}$(t au.status.via): $(t au.via.brew)${C_RESET}"
      else
        local bin; bin="$(autounlock_self_path)" || die "$(t au.needbin)"
        [[ -n "$bin" && -x "$bin" ]] || die "$(t au.needbin)"
        # First deactivate any Homebrew-managed service so we never run two
        # daemons — and ENFORCE it: refuse to proceed if it can't be confirmed.
        _autounlock_stop_brew || die "$(t au.dedup.failed)"
        # The GUI SUDO_ASKPASS admin prompt is the ONLY sudo path (the unsafe
        # passwordless-sudoers option was removed).
        autounlock_write_plist "$bin"
        # bootout an existing instance first so bootstrap is idempotent.
        launchctl bootout "$(_au_domain)/${AUTOUNLOCK_LABEL}" >/dev/null 2>&1 || true
        launchctl bootstrap "$(_au_domain)" "$AUTOUNLOCK_PLIST" >/dev/null 2>&1 || true
        # Only report success (and flip AUTOUNLOCK=on) if the agent actually loaded
        # — never falsely claim success when bootstrap silently failed.
        if ! launchctl print "$(_au_domain)/${AUTOUNLOCK_LABEL}" >/dev/null 2>&1; then
          die "$(t au.install.failed)"
        fi
        AUTOUNLOCK_VIA="self"
        AUTOUNLOCK="on"; save_config
        ok "$(t au.installed)"
        info "${C_DIM}$(t au.status.via): $(t au.via.self)${C_RESET}"
      fi
      info "${C_DIM}$(t au.phase0.note)${C_RESET}"
      ;;
    uninstall)
      # Branch on the recorded mechanism, falling back to autounlock_via when the
      # config never recorded one (e.g. an old config or manual edit).
      local via="$AUTOUNLOCK_VIA"
      case "$via" in self|brew) ;; *) via="$(autounlock_via)" ;; esac
      # Defensively deactivate BOTH mechanisms so a stale record or a self<->brew
      # transition can never leave the other daemon running. Make the ACTIVE
      # (recorded) mechanism's failure VISIBLE; the other is best-effort cleanup.
      if [[ "$via" == "brew" ]]; then
        _autounlock_stop_brew || warn "$(t au.brew.stopfail)"
        _autounlock_stop_self || true    # defensive best-effort on the inactive one
      else
        _autounlock_stop_self || warn "$(t au.self.stopfail)"
        _autounlock_stop_brew || true    # defensive best-effort on the inactive one
      fi
      # Defensive cleanup: remove any legacy passwordless-root rule dropped by a
      # prior build. A leftover ROOT rule must never be hidden — make failure
      # VISIBLE (warn) rather than swallow it with `|| true`.
      if [[ -f "$AUTOUNLOCK_SUDOERS" ]]; then
        if ! sudo rm -f "$AUTOUNLOCK_SUDOERS" 2>/dev/null; then
          warn "$(t au.legacy.sudoers "$AUTOUNLOCK_SUDOERS" "$AUTOUNLOCK_SUDOERS")"
        fi
      fi
      AUTOUNLOCK="off"; save_config
      ok "$(t au.uninstalled)"
      ;;
    status|"")
      step "$(t au.status.header)"
      local present state loaded args via
      via="$AUTOUNLOCK_VIA"; case "$via" in self|brew) ;; *) via="$(autounlock_via)" ;; esac
      if [[ "$AUTOUNLOCK" == "on" ]]; then state="$(t au.status.on)"; else state="$(t au.status.off)"; fi
      printf '  %-18s: %s\n' "$(t au.status.state)" "$state"
      if [[ "$via" == "brew" ]]; then
        printf '  %-18s: %s\n' "$(t au.status.via)" "$(t au.via.brew)"
        # Loaded state comes from `brew services list` (started/stopped/error).
        if brew services list 2>/dev/null | awk '$1=="bltusb"{print $2}' | grep -q '^started$'; then loaded="$(t au.status.yes)"; else loaded="$(t au.status.no)"; fi
        printf '  %-18s: %s\n' "$(t au.status.loaded)" "$loaded"
      else
        printf '  %-18s: %s\n' "$(t au.status.via)" "$(t au.via.self)"
        if [[ -f "$AUTOUNLOCK_PLIST" ]]; then present="$(t au.status.present)"; else present="$(t au.status.absent)"; fi
        printf '  %-18s: %s %s\n' "$(t au.status.plist)" "$present" "${C_DIM}${AUTOUNLOCK_PLIST}${C_RESET}"
        if [[ -f "$AUTOUNLOCK_PLIST" ]]; then
          # Show ProgramArguments so tampering is visible.
          args="$(/usr/libexec/PlistBuddy -c 'Print :ProgramArguments' "$AUTOUNLOCK_PLIST" 2>/dev/null | tr '\n' ' ' | sanitize_display || true)"
          [[ -n "$args" ]] || args="$(grep -A4 ProgramArguments "$AUTOUNLOCK_PLIST" 2>/dev/null | grep '<string>' | sed -E 's/.*<string>(.*)<\/string>.*/\1/' | tr '\n' ' ' | sanitize_display || true)"
          printf '  %-18s: %s\n' "$(t au.status.args)" "$args"
        fi
        if launchctl print "$(_au_domain)/${AUTOUNLOCK_LABEL}" >/dev/null 2>&1; then loaded="$(t au.status.yes)"; else loaded="$(t au.status.no)"; fi
        printf '  %-18s: %s\n' "$(t au.status.loaded)" "$loaded"
      fi
      echo
      info "${C_DIM}$(t au.phase0.note)${C_RESET}"
      ;;
    *) die "$(t au.usage)" ;;
  esac
}

# ---------------------------------------------------------------------------
# Command: vm — build a PINNED + MINIMAL + UPDATABLE anylinuxfs microVM that
# contains only the drivers bltusb needs (cryptsetup / ntfs-3g / mount.nfs),
# living in the normal per-user anylinuxfs store (~/.anylinuxfs) — exactly like
# anylinuxfs already does. Entirely USER-SPACE: NO sudo, NO /Library, NO
# root-owning. See docs/BACKEND-HARDENING-SCOPE.md (the root-own daemon concern
# is decoupled/deferred — a later v1.5 daemon's problem, not this feature's).
#
# It works via anylinuxfs's own supported mechanism: add an [images.bltusb-min]
# entry to the user-owned anylinuxfs.toml pinning `alpine@sha256:<digest>` (+ the
# same libkrunfw kernel URLs copied verbatim from alpine-latest), then
# `anylinuxfs image install bltusb-min` builds it into ~/.anylinuxfs/bltusb-min
# and `apk del` strips the surface.
#
# SUPPLY-CHAIN NOTE on the kernel/modules URLs (audit CODEX-4 / FABLE-M2):
# The `kernel.image_url` / `kernel.modules_url` we copy into the bltusb-min block
# are NOT a live download input at build or boot time. The guest kernel (Image /
# Image-4K) and modules.squashfs are installed by the anylinuxfs HOMEBREW FORMULA
# as sha256-PINNED resources (formula `resource "linux-image"` / `"linux-modules"`)
# into <prefix>/opt/anylinuxfs/libexec/Image* and .../lib/modules.squashfs, and
# the microVM boots from those LOCAL pinned files (ConfigPaths.libexec_path), not
# from the toml URL. Verified: `anylinuxfs image install bltusb-min` produces only
# rootfs+oci under ~/.anylinuxfs/bltusb-min — it does NOT re-fetch the kernel, and
# the store carries no kernel copy. The toml URLs are declarative/metadata that
# anylinuxfs's own toml schema has no digest field for, so adding a sha256 field
# would be silently ignored. Instead we defensively verify the LOCAL pinned kernel
# artifacts' sha256 before a real build (see _vm_verify_kernel) so a tampered
# libexec Image/modules is caught, and rely on Homebrew's formula pin for the URL.
# ---------------------------------------------------------------------------
VM_IMAGE_NAME="bltusb-min"
# Expected sha256 of the LOCAL, Homebrew-formula-pinned microVM kernel/modules
# artifacts (anylinuxfs 0.18.0, libkrunfw v6.12.62-rev1). These are the EXTRACTED
# files as installed under <prefix>/opt/anylinuxfs (not the release-tarball hashes
# the formula pins — Homebrew verifies the tarball, we verify what it unpacked).
# Recomputed at bump time. modules.squashfs matches the formula's linux-modules
# pin exactly; Image/Image-4K are the tar-extracted kernels. A real `vm build`
# verifies whichever kernel it will actually boot; a mismatch aborts the build.
VM_KERNEL_SHA_IMAGE="1c4a26f2f07156b2d50018a97843065e217475947867f54da4e08362389f834e"
VM_KERNEL_SHA_IMAGE_4K="a230b602c530014f930fd8488415569d2b98007dde2a067ee2322109ada24645"
VM_KERNEL_SHA_MODULES="86ed485e4e46ba265261a55e25c92ea15f6118003fcec95a8bafde8ad39f697f"
# The user-owned anylinuxfs image config we edit. Homebrew keeps it at
# <brew-prefix>/etc/anylinuxfs.toml (user-owned, editable — no sudo). The
# BLTUSB_ANYLINUXFS_TOML override lets the test suite point the toml-edit logic
# at an isolated temp copy, so its safety is exercised without touching the real
# config (and without any real build).
if [[ -n "${BLTUSB_ANYLINUXFS_TOML:-}" ]]; then
  ANYLINUXFS_TOML="$BLTUSB_ANYLINUXFS_TOML"
else
  ANYLINUXFS_TOML="$(brew --prefix 2>/dev/null)/etc/anylinuxfs.toml"
  [[ -f "$ANYLINUXFS_TOML" ]] || ANYLINUXFS_TOML="/opt/homebrew/etc/anylinuxfs.toml"
fi

# The current user's anylinuxfs store (matches anylinuxfs's own default).
_vm_store() { printf '%s' "$HOME/.anylinuxfs"; }
_vm_rootfs() { printf '%s' "$(_vm_store)/$VM_IMAGE_NAME/rootfs"; }

# Validate a "sha256:<64 hex>" digest string (returns 0/1, no output).
_vm_is_digest() { [[ "$1" =~ ^sha256:[0-9a-f]{64}$ ]]; }

# Read the base digest anylinuxfs last resolved "alpine:latest" to, from
# ~/.anylinuxfs/alpine/oci/index.json. Prints sha256:… or nothing (return 1).
_vm_index_digest() {
  local idx dig
  idx="$(_vm_store)/alpine/oci/index.json"
  [[ -f "$idx" ]] || return 1
  # Extract the first sha256:<64hex> without needing jq (index.json is tiny).
  dig="$(grep -oE 'sha256:[0-9a-f]{64}' "$idx" 2>/dev/null | head -1)"
  [[ -n "$dig" ]] && printf '%s' "$dig"
}

# The digest currently pinned in the [images.bltusb-min] block of ANYLINUXFS_TOML
# (if any). Prints sha256:… or nothing (return 1).
_vm_pinned_digest() {
  [[ -f "$ANYLINUXFS_TOML" ]] || return 1
  awk '
    /^\[/ { inblk = ($0 ~ /^\[images\.bltusb-min\][[:space:]]*$/) }
    inblk && /docker_ref[[:space:]]*=/ {
      if (match($0, /sha256:[0-9a-f]{64}/)) { print substr($0, RSTART, RLENGTH); exit }
    }' "$ANYLINUXFS_TOML" 2>/dev/null | grep . || return 1
}

# Read a kernel.<key>_url value verbatim from the alpine-latest entry of a toml.
# Prints the URL (unquoted) or nothing.
_vm_toml_kernel_url() {   # <toml> <image_url|modules_url>
  awk -v want="$2" '
    /^\[images\.alpine-latest\][[:space:]]*$/ { inblk=1; next }
    /^\[/ { inblk=0 }
    inblk && $0 ~ ("^kernel\\." want "[[:space:]]*=") {
      sub(/^[^=]*=[[:space:]]*/, ""); gsub(/^"|"$/, ""); print; exit
    }' "$1" 2>/dev/null
}

# Idempotently add/replace the [images.bltusb-min] block in ANYLINUXFS_TOML,
# pinning <digest>, copying the pinned libkrunfw kernel URLs verbatim from the
# file's alpine-latest entry. SAFE: writes to a temp, validates the new block is
# well-formed before moving it into place, and keeps a one-time .bak. Returns 0
# on success, 1 on any error (leaving the original file untouched).
_vm_write_toml() {   # <digest>
  local digest="$1"
  [[ -f "$ANYLINUXFS_TOML" ]] || { err "$(t vm.notoml "$ANYLINUXFS_TOML")"; return 1; }
  # Refuse to write through a symlinked destination: a symlink at $ANYLINUXFS_TOML
  # would otherwise redirect our write to the symlink target (shell redirection /
  # rename both follow the link). The real Homebrew config is a regular file; only
  # a crafted BLTUSB_ANYLINUXFS_TOML override could point here. Fail closed.
  [[ -L "$ANYLINUXFS_TOML" ]] && { err "$(t vm.tomlsymlink "$ANYLINUXFS_TOML")"; return 1; }
  local kimg kmod
  kimg="$(_vm_toml_kernel_url "$ANYLINUXFS_TOML" image_url)"
  kmod="$(_vm_toml_kernel_url "$ANYLINUXFS_TOML" modules_url)"
  [[ -n "$kimg" && -n "$kmod" ]] || { err "$(t vm.nokernelurl "$ANYLINUXFS_TOML")"; return 1; }

  step "$(t vm.tomledit "$ANYLINUXFS_TOML")"
  # One-time backup before the first edit (never overwrite an existing .bak, so
  # the very first pristine copy is preserved across repeated builds/updates).
  local bak="$ANYLINUXFS_TOML.bak"
  # Refuse a symlinked .bak too: a pre-planted symlink at <toml>.bak would otherwise
  # redirect the backup copy through the link. Same fail-closed stance as the dest.
  [[ -L "$bak" ]] && { err "$(t vm.tomlsymlink "$bak")"; return 1; }
  if [[ ! -f "$bak" ]]; then
    cp -p "$ANYLINUXFS_TOML" "$bak" 2>/dev/null || { err "$(t vm.notoml "$bak")"; return 1; }
    info "${C_DIM}$(t vm.tomlbak "$bak")${C_RESET}"
  fi

  # Create the temp in the SAME directory as the destination so the final rename
  # is an atomic same-filesystem mv (no cross-FS copy, no partial-write window).
  local destdir; destdir="$(dirname "$ANYLINUXFS_TOML")"
  local tmp; tmp="$(mktemp "$destdir/.bltusb-toml.XXXXXX")" || return 1
  # Copy every line of the original EXCEPT the existing [images.bltusb-min] block
  # (from its header up to — but not including — the next [section] header or EOF),
  # so other entries and file structure are preserved untouched.
  awk '
    /^\[/ {
      if ($0 ~ /^\[images\.bltusb-min\][[:space:]]*$/) { drop=1; next }
      drop=0
    }
    !drop { print }
  ' "$ANYLINUXFS_TOML" > "$tmp" || { rm -f "$tmp"; return 1; }
  # Append our freshly-generated, pinned block at the end.
  {
    printf '\n[images.%s]\n' "$VM_IMAGE_NAME"
    printf 'base_dir = "%s"\n' "$VM_IMAGE_NAME"
    printf 'docker_ref = "alpine@%s"\n' "$digest"
    printf 'os_type = "Linux"\n'
    printf 'kernel.image_url = "%s"\n' "$kimg"
    printf 'kernel.modules_url = "%s"\n' "$kmod"
  } >> "$tmp" || { rm -f "$tmp"; return 1; }

  # Validate the rewritten file before moving it into place: the block must exist
  # exactly once, carry the pinned docker_ref we just wrote, and both kernel URLs.
  local nblk npin
  nblk="$(grep -cE '^\[images\.bltusb-min\][[:space:]]*$' "$tmp" 2>/dev/null || echo 0)"
  npin="$(grep -cF "docker_ref = \"alpine@$digest\"" "$tmp" 2>/dev/null || echo 0)"
  if [[ "$nblk" -ne 1 || "$npin" -lt 1 ]] \
     || ! grep -q '^kernel.image_url = ' "$tmp" \
     || ! grep -q '^kernel.modules_url = ' "$tmp"; then
    rm -f "$tmp"
    err "$(t vm.tomlbad "$ANYLINUXFS_TOML")"
    return 1
  fi
  # Atomic replace: the temp lives in the destination's own directory, so mv -f is
  # a same-filesystem rename (all-or-nothing — never a truncated/partial file) and,
  # because $ANYLINUXFS_TOML is proven a regular file (not a symlink) above, the
  # rename lands on the real config, not a redirected target. Carry over the
  # original file's mode first so the replacement keeps the user's permissions
  # (mktemp creates 0600); chmod failure is non-fatal (rename still succeeds).
  chmod --reference="$ANYLINUXFS_TOML" "$tmp" 2>/dev/null \
    || { local m; m="$(stat -f '%Lp' "$ANYLINUXFS_TOML" 2>/dev/null)"; [[ -n "$m" ]] && chmod "$m" "$tmp" 2>/dev/null; }
  mv -f "$tmp" "$ANYLINUXFS_TOML" || { rm -f "$tmp"; return 1; }
  ok "$(t vm.tomlok)"
  return 0
}

# Defensive supply-chain check: verify the LOCAL, Homebrew-formula-pinned microVM
# kernel + modules artifacts match the sha256 recorded at bump time BEFORE a real
# build. These are the files the guest actually boots from (libexec Image/Image-4K
# + lib/modules.squashfs); the toml URLs are declarative only (see the note above
# VM_IMAGE_NAME). This catches a tampered/replaced libexec kernel that the toml URL
# pin cannot cover. Best-effort: if the anylinuxfs prefix or files can't be located
# (non-standard install), WARN and continue rather than block the user's build.
# Returns 0 to proceed, 1 only on a positive hash MISMATCH (abort the build).
_vm_verify_kernel() {
  local pfx img img4k mods pfx_ok=0
  pfx="$(brew --prefix anylinuxfs 2>/dev/null)"
  [[ -n "$pfx" && -d "$pfx" ]] || pfx="$(brew --prefix 2>/dev/null)/opt/anylinuxfs"
  [[ -n "$pfx" && -d "$pfx/libexec" ]] && pfx_ok=1
  img="$pfx/libexec/Image"; img4k="$pfx/libexec/Image-4K"; mods="$pfx/lib/modules.squashfs"
  # Genuinely uncheckable (non-standard install / no shasum): revert to the
  # Homebrew formula's own sha256 pin (baseline) rather than block the build.
  { [[ "$pfx_ok" -eq 1 ]] && command -v shasum >/dev/null 2>&1; } || { warn "$(t vm.kernelunknown)"; return 0; }
  # Prefix IS resolvable — every pinned artifact must be PRESENT and MATCH. A
  # missing expected artifact is anomalous (tamper/removal), so fail closed rather
  # than silently skip it.
  _vm_sha_ok() {   # <file> <expected> — 0 match, 1 missing-or-mismatch
    local f="$1" want="$2" got
    [[ -f "$f" ]] || { err "$(t vm.kernelbad "$f")"; return 1; }
    got="$(shasum -a 256 "$f" 2>/dev/null | awk '{print $1}')"
    [[ "$got" == "$want" ]] && return 0
    err "$(t vm.kernelbad "$f")"; return 1
  }
  local bad=0
  _vm_sha_ok "$img"   "$VM_KERNEL_SHA_IMAGE"    || bad=1
  _vm_sha_ok "$img4k" "$VM_KERNEL_SHA_IMAGE_4K" || bad=1
  _vm_sha_ok "$mods"  "$VM_KERNEL_SHA_MODULES"  || bad=1
  [[ "$bad" -eq 1 ]] && return 1
  ok "$(t vm.kernelok)"
  return 0
}

# Build the pinned image. Dry-run PRINTS the command instead of running the
# slow/networked build. anylinuxfs bakes a fixed default driver set (cryptsetup/
# BitLocker, ntfs-3g, vfat, ext/btrfs via kernel modules, nfs …) — exactly the
# broad FS coverage we want; there is no supported way to remove baked-in defaults
# (`apk del` only manages user-ADDED custom packages), so we don't try to strip.
_vm_build_image() {   # <dryrun:true|false>
  local dryrun="$1"
  if [[ "$dryrun" == "true" ]]; then
    step "$(t vm.dryrun)"
    printf '  anylinuxfs image install %s\n' "$VM_IMAGE_NAME"
    warn "$(t vm.dryskip)"
    return 0
  fi
  # Defensively verify the local pinned kernel/modules before the real build.
  _vm_verify_kernel || return 1
  step "$(t vm.buildstep)"
  anylinuxfs image install "$VM_IMAGE_NAME" || return 1
  return 0
}

# Does `anylinuxfs image list` currently show bltusb-min? (return 0/1, no output)
_vm_image_listed() {
  anylinuxfs image list 2>/dev/null | grep -q "$VM_IMAGE_NAME"
}

# Resolve the digest to pin: --digest (if given + valid) else the index.json the
# base image was last resolved to. Prints the digest on stdout; dies if neither.
_vm_pick_digest() {   # <digest-arg-or-empty>
  local arg="$1" dig
  if [[ -n "$arg" ]]; then
    _vm_is_digest "$arg" || die "$(t vm.baddigest "$arg")"
    info "$(t vm.digestarg "$arg")" >&2
    printf '%s' "$arg"; return 0
  fi
  info "$(t vm.digestask)" >&2
  dig="$(_vm_index_digest 2>/dev/null || true)"
  [[ -n "$dig" ]] || die "$(t vm.nodigest)"
  info "$(t vm.digestfrom "$(_vm_store)/alpine/oci/index.json" "$dig")" >&2
  printf '%s' "$dig"
}

# Warn (never block) if the installed anylinuxfs isn't the pinned/reviewed version.
_vm_version_warn() {
  local av; av="$(anylinuxfs --version 2>/dev/null | awk '{print $NF}')"
  [[ -n "$av" && "$av" != "$ANYLINUXFS_PINNED_VERSION" ]] \
    && warn "$(t vm.verwarn "$av" "$ANYLINUXFS_PINNED_VERSION")"
  return 0
}

cmd_vm() {
  local sub="${1:-}"; shift || true
  local digest_arg="" dryrun="false" want_digest="false" a
  for a in "$@"; do
    if [[ "$want_digest" == "true" ]]; then digest_arg="$a"; want_digest="false"; continue; fi
    case "$a" in
      --dry-run)  dryrun="true" ;;
      --digest)   want_digest="true" ;;   # value is the NEXT arg
      sha256:*)   digest_arg="$a" ;;
      *)          warn "ignoring unknown arg: $a" ;;
    esac
  done
  # Env dry-run hook (used by the smoke test) so a real build is never triggered.
  [[ "${BLTUSB_VM_DRYRUN:-}" == "1" ]] && dryrun="true"

  case "$sub" in
    build)
      ensure_installed
      _vm_version_warn
      local digest; digest="$(_vm_pick_digest "$digest_arg")" || exit 1
      ok "$(t vm.pinned "$digest")"
      _vm_write_toml "$digest" || exit 1
      _vm_build_image "$dryrun" || exit 1
      ok "$(t vm.buildok)"
      info "$(t vm.keep)"
      info "${C_DIM}$(t vm.usenote "$(_vm_store)/$VM_IMAGE_NAME" "$digest")${C_RESET}"
      ;;
    update)
      ensure_installed
      _vm_version_warn
      local old; old="$(_vm_pinned_digest 2>/dev/null || true)"
      [[ -n "$old" ]] || die "$(t vm.up.nocurrent "$ANYLINUXFS_TOML")"
      step "$(t vm.up.resolve)"
      # Refresh ~/.anylinuxfs/alpine so index.json carries the fresh digest (unless
      # the user pinned one explicitly with --digest). Dry-run skips the refresh.
      if [[ -z "$digest_arg" && "$dryrun" != "true" ]]; then
        anylinuxfs image install alpine-latest || true
      fi
      local new; new="$(_vm_pick_digest "$digest_arg")" || exit 1
      if [[ "$new" == "$old" ]]; then
        ok "$(t vm.up.same "$old")"
        return 0
      fi
      info "$(t vm.up.oldnew "$old" "$new")"
      printf '%s' "${C_CYN}$(t vm.up.confirm)${C_RESET}"
      local ans; read -r ans
      case "${ans:-N}" in [yY]*) : ;; *) die "$(t vm.up.cancelled)" ;; esac
      ok "$(t vm.pinned "$new")"
      _vm_write_toml "$new" || exit 1
      _vm_build_image "$dryrun" || exit 1
      ok "$(t vm.buildok)"
      info "$(t vm.keep)"
      if [[ "$dryrun" != "true" ]]; then
        if _vm_image_listed; then ok "$(t vm.up.verify)"; else warn "$(t vm.up.verifyfail)"; fi
      fi
      ;;
    status|"")
      step "$(t vm.st.header)"
      local built
      if _vm_image_listed || [[ -d "$(_vm_rootfs)" ]]; then built="$(t vm.st.present)"; else built="$(t vm.st.absent)"; fi
      printf '  %-16s: %s\n' "$(t vm.st.built)" "$built"
      local digest; digest="$(_vm_pinned_digest 2>/dev/null || true)"
      printf '  %-16s: %s\n' "$(t vm.st.digest)" "${digest:-$(t vm.st.none)}"
      # FS coverage present in the built rootfs (user-space; no sudo). Glob the two
      # sbin dirs and keep the mount helpers + cryptsetup — these show which
      # filesystems the microVM can actually mount ("一切基本驱动").
      local rootfs drivers="" d base seen=""
      rootfs="$(_vm_rootfs)"
      for d in "$rootfs"/sbin/* "$rootfs"/usr/sbin/*; do
        # -L too: guest mount helpers (mount.ntfs -> /bin/ntfs-3g) are absolute
        # symlinks that only resolve inside the VM, so -e alone would drop them.
        [[ -e "$d" || -L "$d" ]] || continue
        base="${d##*/}"
        case "$base" in
          cryptsetup|mount.*)
            case " $seen " in *" $base "*) ;; *) seen="$seen $base"; drivers="$drivers$base " ;; esac
            ;;
        esac
      done
      printf '  %-16s: %s\n' "$(t vm.st.drivers)" "${drivers:-$(t vm.st.none)}"
      if [[ "$built" == "$(t vm.st.absent)" ]]; then
        echo
        info "$(t vm.st.notbuilt)"
      fi
      ;;
    *) die "$(t vm.usage)" ;;
  esac
}

# ---------------------------------------------------------------------------
# Command: lang
# ---------------------------------------------------------------------------
cmd_lang() {
  local sub="${1:-show}"
  case "$sub" in
    show|"")
      step "$(t lang.header)"
      printf '  %-12s: %s %s\n' "$(t lang.effective)" "$(lang_name "$BLTUSB_LANG_CODE")" "${C_DIM}($BLTUSB_LANG_CODE)${C_RESET}"
      if [[ -n "$LANG_OVERRIDE" ]]; then
        printf '  %-12s: %s\n' "$(t lang.override)" "$(lang_name "$LANG_OVERRIDE")"
      else
        printf '  %-12s: %s\n' "$(t lang.override)" "${C_DIM}$(t lang.auto)${C_RESET}"
      fi
      ;;
    en|zh-CN|zh-TW)
      LANG_OVERRIDE="$sub"; save_config
      BLTUSB_LANG_CODE="$sub"
      ok "$(t lang.set "$(lang_name "$sub")")"
      ;;
    auto)
      LANG_OVERRIDE=""; save_config
      BLTUSB_LANG_CODE="$(resolve_lang)"
      ok "$(t lang.reset)"
      ;;
    *) die "$(t lang.unknown "$sub")" ;;
  esac
}

