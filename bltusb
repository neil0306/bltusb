# ---------------------------------------------------------------------------
# Config load/save
# ---------------------------------------------------------------------------
# Parse the config WITHOUT `source` so a hand-edited/crafted config can never
# execute code. Only known keys are honored; values are validated in main().
load_config() {
  [[ -f "$CONFIG_FILE" ]] || return 0
  local line key val
  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in ''|\#*) continue ;; esac
    key="${line%%=*}"; val="${line#*=}"
    val="${val%\"}"; val="${val#\"}"   # strip one layer of surrounding quotes
    case "$key" in
      DEVICE)        DEVICE="$val" ;;
      DEFAULT_MODE)  DEFAULT_MODE="$val" ;;
      LANG_OVERRIDE) LANG_OVERRIDE="$val" ;;
    esac
  done < "$CONFIG_FILE"
}

# Reject anything untrusted read from the config file (fail closed).
validate_config() {
  case "$DEFAULT_MODE" in ro|rw) ;; *) DEFAULT_MODE="ro" ;; esac
  case "$LANG_OVERRIDE" in ""|en|zh-CN|zh-TW) ;; *) LANG_OVERRIDE="" ;; esac
  [[ -z "$DEVICE" || "$DEVICE" =~ ^/dev/disk[0-9]+s[0-9]+$ ]] || DEVICE=""
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
# bltusb config — generated by \`bltusb config\` / \`bltusb lang\`, editable by hand
# DEVICE        : target partition, e.g. /dev/disk4s1; empty = auto-detect BitLocker volume
# DEFAULT_MODE  : default mount mode, ro (read-only, recommended) or rw (read-write)
# LANG_OVERRIDE : menu language, empty = follow system; en / zh-CN / zh-TW
DEVICE="${DEVICE}"
DEFAULT_MODE="${DEFAULT_MODE}"
LANG_OVERRIDE="${LANG_OVERRIDE}"
EOF
  ok "$(t cfg.saved "${C_DIM}${CONFIG_FILE}${C_RESET}")"
}

# ---------------------------------------------------------------------------
# Password (stored in the macOS Keychain)
# ---------------------------------------------------------------------------
keychain_get() {
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w 2>/dev/null || true
}
keychain_set() {
  security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$1" >/dev/null
}
keychain_del() {
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" >/dev/null 2>&1 || true
}

# Password resolution order: env ALFS_PASSPHRASE > Keychain > interactive.
# If prompted interactively, offer to remember it in the Keychain.
get_passphrase() {
  if [[ -n "${ALFS_PASSPHRASE:-}" ]]; then
    printf '%s' "$ALFS_PASSPHRASE"; return 0
  fi
  local p; p="$(keychain_get)"
  if [[ -n "$p" ]]; then
    printf '%s' "$p"; return 0
  fi
  printf '%s' "${C_CYN}$(t pass.prompt)${C_RESET}" >&2
  local pw; read -rs pw; printf '\n' >&2
  [[ -n "$pw" ]] || die "$(t pass.empty)"
  printf '%s' "${C_CYN}$(t pass.savekey)${C_RESET}" >&2
  local ans; read -r ans
  case "${ans:-Y}" in [nN]*) : ;; *) keychain_set "$pw" ;; esac
  printf '%s' "$pw"
}

# ---------------------------------------------------------------------------
# Dependency check / install
# ---------------------------------------------------------------------------
have_anylinuxfs() { command -v anylinuxfs >/dev/null 2>&1; }

ensure_installed() {
  have_anylinuxfs && return 0
  warn "$(t inst.notfound)"
  printf '%s' "$(t inst.ask)" >&2
  local ans; read -r ans
  case "${ans:-Y}" in
    [nN]*) die "$(t inst.cancelled)" ;;
    *) cmd_install ;;
  esac
}

cmd_install() {
  step "$(t inst.header)"
  command -v brew >/dev/null 2>&1 || die "$(t inst.nobrew)"
  if have_anylinuxfs; then
    ok "$(t inst.already "$(anylinuxfs --version 2>/dev/null || echo ready)")"
    return 0
  fi
  info "brew tap nohajc/anylinuxfs"
  brew tap nohajc/anylinuxfs
  info "brew trust nohajc/anylinuxfs  ${C_DIM}# $(t inst.trustnote)${C_RESET}"
  brew trust nohajc/anylinuxfs || warn "$(t inst.trustfail)"
  info "brew install anylinuxfs"
  brew install anylinuxfs
  if have_anylinuxfs; then ok "$(t inst.done)"; else die "$(t inst.missing)"; fi
}

# ---------------------------------------------------------------------------
# Device detection
# ---------------------------------------------------------------------------
# Whether a partition is a BitLocker volume (reads the -FVE-FS- signature at
# offset 3). Needs sudo to read the raw device.
is_bitlocker() {
  local dev="$1" sig
  dev="${dev#/dev/}"
  # Raw char devices require sector-aligned reads, so read one 512B sector and
  # then slice bytes 3..10 (a bare `dd bs=1 skip=3` on /dev/rdiskN fails with
  # "Invalid argument").
  sig="$(sudo -n dd if="/dev/r${dev}" bs=512 count=1 2>/dev/null | dd bs=1 skip=3 count=8 2>/dev/null | tr -d '\0' || true)"
  [[ "$sig" == "$BITLOCKER_SIGNATURE" ]]
}

# Heuristic: does the partition type look like a Windows/BitLocker volume?
looks_windows() {
  case "$1" in
    *Windows*|*Microsoft*|*NTFS*|*BitLocker*|*FAT*) return 0 ;;
    *) return 1 ;;
  esac
}

# List partition identifiers (diskNsM) on all external physical disks
list_external_partitions() {
  diskutil list external physical 2>/dev/null \
    | grep -oE 'disk[0-9]+s[0-9]+' | sort -u
}

# Emit one row per external partition: "id<TAB>size<TAB>type"
list_partition_rows() {
  diskutil list external physical 2>/dev/null | awk '
    /^ +[0-9]+:/ && $NF ~ /^disk[0-9]+s[0-9]+$/ {
      id=$NF; size=$(NF-2)" "$(NF-1); type="";
      for (i=2; i<=NF-3; i++) type = type (type==""?"":" ") $i;
      print id "\t" size "\t" type
    }'
}

# Auto-detect the BitLocker partition: prefer signature match; otherwise fall
# back to "the only external partition".
autodetect_device() {
  local parts detected=() p
  parts="$(list_external_partitions)"
  [[ -n "$parts" ]] || { err "$(t det.nodisk)"; return 1; }

  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    if is_bitlocker "$p" 2>/dev/null; then detected+=("/dev/$p"); fi
  done <<< "$parts"

  if [[ ${#detected[@]} -eq 1 ]]; then
    printf '%s' "${detected[0]}"; return 0
  elif [[ ${#detected[@]} -gt 1 ]]; then
    err "$(t det.multi "${detected[*]}")"
    err "$(t det.hintcfg)"
    return 1
  fi

  local arr=(); while IFS= read -r p; do [[ -n "$p" ]] && arr+=("/dev/$p"); done <<< "$parts"
  if [[ ${#arr[@]} -eq 1 ]]; then
    warn "$(t det.onlyone "${arr[0]}")"
    printf '%s' "${arr[0]}"; return 0
  fi
  err "$(t det.cantauto "${arr[*]:-N/A}")"
  err "$(t det.hintcfg2)"
  return 1
}

# Resolve the device to use: CLI arg > config DEVICE > auto-detect
resolve_device() {
  local arg="${1:-}"
  if [[ -n "$arg" ]]; then printf '%s' "$arg"; return 0; fi
  if [[ -n "$DEVICE" ]]; then printf '%s' "$DEVICE"; return 0; fi
  autodetect_device
}

# ---------------------------------------------------------------------------
# Mount state & core mount
# ---------------------------------------------------------------------------
current_mountpoint() {
  anylinuxfs status 2>/dev/null | grep -oE '/Volumes/[^ ]+' | head -1 || true
}
is_mounted() { [[ -n "$(current_mountpoint)" ]]; }

# perform_mount <device> <ro|rw> <do_open:true|false>
perform_mount() {
  local dev="$1" mode="$2" do_open="${3:-false}"
  local pass; pass="$(get_passphrase)"
  local opts=(-w false)
  # Fail closed: only an explicit "rw" gets read-write; anything else is read-only.
  [[ "$mode" == "rw" ]] || opts+=(-o ro)

  step "$(t mnt.mounting "$dev" "$mode")"
  [[ "$mode" == "rw" ]] && warn "$(t mnt.rwwarn)"
  info "sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount ${opts[*]} ${dev}"

  # Pass the passphrase via the environment (not as a sudo argv), so it never
  # appears in `ps`. --preserve-env keeps it across sudo's env reset.
  if ALFS_PASSPHRASE="$pass" sudo --preserve-env=ALFS_PASSPHRASE anylinuxfs mount "${opts[@]}" "$dev"; then
    local mp; mp="$(current_mountpoint)"
    ok "$(t mnt.success "${mp:+ → $mp}")  ${C_DIM}(${mode})${C_RESET}"
    [[ -n "$mp" ]] && printf '   %s\n' "${C_DIM}$(t mnt.cd "$mp")${C_RESET}"
    if [[ "$do_open" == "true" && -n "$mp" ]]; then open "$mp"; fi
    return 0
  else
    err "$(t mnt.fail)"
    err "$(t mnt.failhint)"
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Interactive wizard (default action when run with no arguments)
# ---------------------------------------------------------------------------
cmd_auto() {
  ensure_installed

  if is_mounted; then
    local mp; mp="$(current_mountpoint)"
    info "$(t wiz.mountedopen "$mp")"
    open "$mp"; ok "$(t open.done)"
    return 0
  fi

  step "$(t wiz.detecting)"
  local ids=() sizes=() types=() isbl=() rec=0 n=0 id size type
  while IFS=$'\t' read -r id size type; do
    [[ -n "$id" ]] || continue
    ids+=("$id"); sizes+=("$size"); types+=("$type")
    if is_bitlocker "$id" 2>/dev/null; then isbl+=("bl"); [[ $rec -eq 0 ]] && rec=$((n+1))
    elif looks_windows "$type"; then isbl+=("win"); [[ $rec -eq 0 ]] && rec=$((n+1))
    else isbl+=("no"); fi
    n=$((n+1))
  done <<< "$(list_partition_rows)"

  [[ $n -gt 0 ]] || { err "$(t wiz.none)"; return 1; }
  [[ $rec -eq 0 ]] && rec=1

  local choice="$rec"
  if [[ $n -eq 1 ]]; then
    choice=1
    info "/dev/${ids[0]}  ${C_DIM}${sizes[0]}  ${types[0]}${C_RESET}"
  else
    echo; printf '%s\n' "$(t wiz.pick)"
    local i tag
    for ((i=0; i<n; i++)); do
      tag=""
      case "${isbl[$i]}" in
        bl)  tag="  ${C_GRN}BitLocker${C_RESET}" ;;
        win) tag="  ${C_YEL}Windows${C_RESET}" ;;
      esac
      [[ $((i+1)) -eq $rec ]] && tag="$tag  ${C_DIM}($(t wiz.recommended))${C_RESET}"
      printf '  %s) %-12s %-9s %s%s\n' "$((i+1))" "/dev/${ids[$i]}" "${sizes[$i]}" "${types[$i]}" "$tag"
    done
    printf '%s' "$(t wiz.devask "$rec")"
    local ans; read -r ans
    [[ -n "$ans" ]] && choice="$ans"
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > n )); then die "$(t wiz.invalid)"; fi
  fi

  local dev="/dev/${ids[$((choice-1))]}"

  # Mode: default read-only
  echo; printf '%s\n' "$(t wiz.modehdr)"
  printf '  1) %s\n' "$(t wiz.modero)"
  printf '  2) %s\n' "$(t wiz.moderw)"
  printf '%s' "$(t wiz.modeask)"
  local mans mode="ro"; read -r mans
  [[ "$mans" == "2" ]] && mode="rw"

  echo
  perform_mount "$dev" "$mode" "false" || return 1

  # Offer to open in Finder
  local mp; mp="$(current_mountpoint)"
  if [[ -n "$mp" ]]; then
    printf '%s' "$(t wiz.openask)"
    local oans; read -r oans
    case "${oans:-Y}" in [nN]*) : ;; *) open "$mp"; ok "$(t open.done)" ;; esac
  fi
  [[ "$mode" == "ro" ]] && info "${C_DIM}$(t wiz.rwhint)${C_RESET}"
}

# ---------------------------------------------------------------------------
# Commands: mount / rw / umount / status / detect / open
# ---------------------------------------------------------------------------
cmd_mount() {
  local mode="$DEFAULT_MODE" dev_arg="" do_open="false" a
  for a in "$@"; do
    case "$a" in
      ro|readonly) mode="ro" ;;
      rw|readwrite) mode="rw" ;;
      --open) do_open="true" ;;
      /dev/*) dev_arg="$a" ;;
      disk*) dev_arg="/dev/$a" ;;
      *) warn "ignoring unknown arg: $a" ;;
    esac
  done

  ensure_installed

  if is_mounted; then
    warn "$(t mnt.already "$(current_mountpoint)")"
    warn "$(t mnt.switchhint)"
    return 0
  fi

  local dev; dev="$(resolve_device "$dev_arg")" || exit 1
  perform_mount "$dev" "$mode" "$do_open" || exit 1
}

cmd_rw() { cmd_mount rw "$@"; }

cmd_umount() {
  if ! is_mounted; then
    info "$(t umt.none)"
    return 0
  fi
  local mp; mp="$(current_mountpoint)"
  step "$(t umt.unmounting "$mp")"
  if sudo anylinuxfs unmount; then
    ok "$(t umt.done)"
  else
    err "$(t umt.fail)"
    exit 1
  fi
}

cmd_status() {
  ensure_installed
  step "$(t st.header)"
  local out; out="$(anylinuxfs status 2>/dev/null || true)"
  if [[ -n "$out" ]]; then
    printf '%s\n' "$out"
    local mp; mp="$(current_mountpoint)"
    [[ -n "$mp" ]] && ok "$(t st.mounted "$mp")"
  else
    info "$(t st.none)"
  fi
  echo
  step "$(t st.extdisks)"
  diskutil list external physical 2>/dev/null || info "$(t st.noext)"
}

cmd_detect() {
  step "$(t det.header)"
  local parts p any="false"
  parts="$(list_external_partitions)"
  [[ -n "$parts" ]] || { info "$(t det.nopart)"; return 0; }
  while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    if is_bitlocker "$p" 2>/dev/null; then
      ok "$(t det.isbl "${C_GRN}/dev/$p${C_RESET}")"
      any="true"
    else
      printf '   %s\n' "${C_DIM}$(t det.notbl "/dev/$p")${C_RESET}"
    fi
  done <<< "$parts"
  [[ "$any" == "true" ]] || warn "$(t det.noconfirm)"
}

cmd_open() {
  if is_mounted; then
    open "$(current_mountpoint)"; ok "$(t open.done)"
  else
    cmd_mount --open "$@"
  fi
}

# ---------------------------------------------------------------------------
# Command: config
# ---------------------------------------------------------------------------
cmd_config() {
  local sub="${1:-show}"; shift || true
  case "$sub" in
    show|"")
      step "$(t cfg.header)"
      printf '  %-9s: %s\n' "$(t cfg.file)"   "$CONFIG_FILE"
      printf '  %-9s: %s\n' "$(t cfg.device)" "${DEVICE:-$(t cfg.auto)}"
      printf '  %-9s: %s\n' "$(t cfg.mode)"   "$DEFAULT_MODE"
      printf '  %-9s: %s\n' "$(t cfg.lang)"   "$(lang_name "$BLTUSB_LANG_CODE")"
      if [[ -n "$(keychain_get)" ]]; then
        printf '  %-9s: %s\n' "$(t cfg.password)" "${C_GRN}$(t cfg.pass.set)${C_RESET}"
      else
        printf '  %-9s: %s\n' "$(t cfg.password)" "${C_YEL}$(t cfg.pass.unset)${C_RESET}"
      fi
      ;;
    set-password|password|passwd)
      local pw
      if [[ -n "${1:-}" ]]; then pw="$1"; else
        printf '%s' "${C_CYN}$(t cfg.pwprompt)${C_RESET}"; read -rs pw; printf '\n'
      fi
      [[ -n "$pw" ]] || die "$(t cfg.pwempty)"
      keychain_set "$pw"; ok "$(t cfg.pwsaved)"
      ;;
    set-device|device)
      local d="${1:-}"
      [[ -n "$d" ]] || { printf '%s' "$(t cfg.devprompt)"; read -r d; }
      if [[ -n "$d" && ! "$d" =~ ^/dev/disk[0-9]+s[0-9]+$ ]]; then die "$(t cfg.deverr)"; fi
      DEVICE="$d"; save_config
      ;;
    set-mode|mode)
      local m="${1:-}"
      case "$m" in ro|rw) DEFAULT_MODE="$m"; save_config ;; *) die "$(t cfg.modeerr)" ;; esac
      ;;
    clear-password)
      keychain_del; ok "$(t cfg.pwcleared)"
      ;;
    init)
      step "$(t cfg.init.header)"
      printf '%s' "$(t cfg.init.pw)"; local pw; read -rs pw; printf '\n'
      [[ -n "$pw" ]] && { keychain_set "$pw"; ok "$(t cfg.init.pwsaved)"; }
      printf '%s' "$(t cfg.init.dev)"; read -r DEVICE
      printf '%s' "$(t cfg.init.mode)"; local m; read -r m
      if [[ "$m" == "rw" ]]; then DEFAULT_MODE="rw"; else DEFAULT_MODE="ro"; fi
      save_config
      ;;
    *) die "$(t cfg.unknownsub "$sub")" ;;
  esac
}

# ---------------------------------------------------------------------------
# Command: lang
# ---------------------------------------------------------------------------
cmd_lang() {
  local sub="${1:-show}"
  case "$sub" in
    show|"")
      step "$(t lang.header)"
      printf '  %-12s: %s %s\n' "$(t lang.effective)" "$(lang_name "$BLTUSB_LANG_CODE")" "${C_DIM}($BLTUSB_LANG_CODE)${C_RESET}"
      if [[ -n "$LANG_OVERRIDE" ]]; then
        printf '  %-12s: %s\n' "$(t lang.override)" "$(lang_name "$LANG_OVERRIDE")"
      else
        printf '  %-12s: %s\n' "$(t lang.override)" "${C_DIM}$(t lang.auto)${C_RESET}"
      fi
      ;;
    en|zh-CN|zh-TW)
      LANG_OVERRIDE="$sub"; save_config
      BLTUSB_LANG_CODE="$sub"
      ok "$(t lang.set "$(lang_name "$sub")")"
      ;;
    auto)
      LANG_OVERRIDE=""; save_config
      BLTUSB_LANG_CODE="$(resolve_lang)"
      ok "$(t lang.reset)"
      ;;
    *) die "$(t lang.unknown "$sub")" ;;
  esac
}

